"hrv.interpretation.uncertain.bad_quality.recommendation" = "Powtórz skan w pozycji siedzącej, spokojnie, z ciepłymi dłońmi i równym naciskiem palca.";
"hrv.interpretation.baseline.none.summary" = "Twój punkt odniesienia HRV jest wciąż budowany.";
"hrv.interpretation.baseline.none.recommendation" = "Mierz dalej o tej samej porze każdego ranka. Po kilku kolejnych skanach wskazówki staną się bardziej osobiste.";
"hrv.interpretation.push.summary" = "Twój sygnał regeneracji wygląda dziś mocno.";
"hrv.interpretation.push.recommendation" = "To może być dobry dzień na trening, koncentrację lub ważną pracę, jeśli czujesz się dobrze.";
"hrv.interpretation.normal.summary" = "Twoje HRV wygląda dziś na zrównoważone.";
