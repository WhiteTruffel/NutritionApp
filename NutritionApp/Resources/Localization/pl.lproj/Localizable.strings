"hrv.onboarding.what_is_hrv.title" = "Czym jest HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV to zmienność rytmu serca. Mierzy drobne zmiany czasu między uderzeniami serca.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Twoje serce nie bije jak idealny metronom.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Elastyczny rytm może odzwierciedlać lepszą zdolność adaptacji układu nerwowego.";
"hrv.onboarding.what_is_hrv.bullet_3" = "Na HRV mogą wpływać sen, stres, choroba, trening, alkohol, kofeina, nawodnienie i presja emocjonalna.";
"hrv.onboarding.camera_scan.title" = "Jak działa skan telefonem";
"hrv.onboarding.camera_scan.body" = "Kamera rejestruje drobne zmiany koloru opuszki palca. Zmiany te podążają za falą tętna, a aplikacja szacuje czas między uderzeniami.";
"hrv.onboarding.camera_scan.bullet_1" = "To szacunek HRV oparty na kamerze.";
"hrv.onboarding.camera_scan.bullet_2" = "Jest przydatny do trendów, gdy mierzysz starannie.";
"hrv.onboarding.camera_scan.bullet_3" = "To nie jest EKG ani diagnoza medyczna.";
"hrv.onboarding.best_time.title" = "Kiedy mierzyć";
"hrv.onboarding.best_time.body" = "Dla najlepszego trendu mierz o tej samej porze każdego ranka, przed kofeiną, jedzeniem, treningiem lub stresem w pracy.";
"hrv.onboarding.best_time.bullet_1" = "Mierz po przebudzeniu.";
"hrv.onboarding.best_time.bullet_2" = "Mierz przed kofeiną lub jedzeniem.";
"hrv.onboarding.best_time.bullet_3" = "Codziennie przyjmuj tę samą pozycję ciała.";
"hrv.onboarding.best_time.bullet_4" = "Staraj się mierzyć w tym samym porannym przedziale czasowym.";
"hrv.onboarding.preparation.title" = "Zanim zaczniesz";
"hrv.onboarding.preparation.body" = "Bezruch ma znaczenie. HRV jest czułe, więc najczystsze skany powstają, gdy ciało jest spokojne, a palec nieruchomy.";
"hrv.onboarding.preparation.bullet_1" = "Usiądź lub połóż się.";
"hrv.onboarding.preparation.bullet_2" = "Odpocznij przez jedną do dwóch minut.";
"hrv.onboarding.preparation.bullet_3" = "Ogrzej dłonie, jeśli masz zimne palce.";
"hrv.onboarding.preparation.bullet_4" = "Oddychaj normalnie i nie rozmawiaj.";
"hrv.onboarding.finger_placement.title" = "Delikatnie połóż palec";
"hrv.onboarding.finger_placement.body" = "Zakryj w całości tylną kamerę opuszką palca. Użyj delikatnego, równomiernego nacisku. Zbyt mocny nacisk zmienia przepływ krwi i skan staje się mniej wiarygodny.";
"hrv.onboarding.finger_placement.bullet_1" = "Zakryj kamerę w całości.";
"hrv.onboarding.finger_placement.bullet_2" = "Nie naciskaj zbyt mocno.";
"hrv.onboarding.finger_placement.bullet_3" = "Trzymaj palec nieruchomo.";
"hrv.onboarding.during_scan.title" = "Podczas skanu";
"hrv.onboarding.during_scan.body" = "Po prostu oddychaj normalnie. Nie próbuj poprawiać wyniku. Celem jest uchwycenie Twojego prawdziwego stanu.";
"hrv.onboarding.during_scan.bullet_1" = "Pozostań nieruchomo.";
"hrv.onboarding.during_scan.bullet_2" = "Nie rozmawiaj.";
"hrv.onboarding.during_scan.bullet_3" = "Oddychaj naturalnie.";
"hrv.onboarding.scan_length.title" = "Wybierz głębokość skanu";
"hrv.onboarding.scan_length.body" = "Krótkie skany są przydatne do codziennych trendów. Dłuższe skany odblokowują głębsze wskaźniki HRV.";
"hrv.onboarding.scan_length.bullet_1" = "Szybki skan: 60 do 120 sekund dla codziennej gotowości.";
"hrv.onboarding.scan_length.bullet_2" = "Standardowy skan: 5 minut dla głębszej analizy.";
"hrv.onboarding.scan_length.bullet_3" = "Głęboki skan: 300 czystych uderzeń lub więcej dla zaawansowanych wskaźników HRV.";
"hrv.onboarding.results.title" = "Jak czytać wynik";
"hrv.onboarding.results.body" = "Jeden skan to migawka. Twój osobisty trend jest ważniejszy niż pojedyncza wartość.";
"hrv.onboarding.results.bullet_1" = "Twój osobisty punkt odniesienia liczy się bardziej niż ogólny zakres.";
"hrv.onboarding.results.bullet_2" = "Niskie HRV może odzwierciedlać stres, słaby sen, chorobę, odwodnienie, alkohol lub ciężki trening.";
"hrv.onboarding.results.bullet_3" = "Wysokie HRV może oznaczać dobrą regenerację, ale jeśli czujesz się wyczerpany, może też odzwierciedlać potrzebę regeneracji.";
"hrv.onboarding.daily_guidance.title" = "Twoje codzienne wskazówki";
"hrv.onboarding.daily_guidance.body" = "Aplikacja wykorzystuje Twój trend HRV, aby codzienne przypomnienia były bardziej osobiste.";
"hrv.onboarding.daily_guidance.bullet_1" = "Jeśli mierzyłeś dziś, przypomnienia mogą zawierać wskazówki oparte na HRV.";
"hrv.onboarding.daily_guidance.bullet_2" = "Jeśli nie mierzyłeś, przypomnienia delikatnie zachęcą Cię do wykonania skanu.";
"hrv.onboarding.daily_guidance.bullet_3" = "Im bardziej regularnie mierzysz, tym lepsze stają się Twoje wskazówki.";
"hrv.onboarding.limitations.title" = "Ważne ograniczenia";
"hrv.onboarding.limitations.body" = "HRV nie jest diagnozą medyczną. Ta aplikacja nie wykrywa chorób serca, arytmii ani sytuacji nagłych.";
"hrv.onboarding.limitations.bullet_1" = "HRV z kamery to szacunek, nie EKG.";
"hrv.onboarding.limitations.bullet_2" = "Na dokładność mogą wpływać ruch, zimne palce, nacisk, leki i arytmie.";
"hrv.onboarding.limitations.bullet_3" = "Jeśli odczuwasz ból w klatce piersiowej, omdlenie, silną duszność lub nietypowe objawy, szukaj pomocy medycznej.";
"hrv.onboarding.first_scan.title" = "Gotowy na pierwszy skan?";
"hrv.onboarding.first_scan.body" = "Wykonaj teraz pierwszy spokojny skan, aby aplikacja mogła zacząć budować Twój osobisty punkt odniesienia HRV.";
"hrv.onboarding.first_scan.primary_cta" = "Rozpocznij skan HRV";
"hrv.onboarding.first_scan.secondary_cta" = "Przypomnij mi później";
