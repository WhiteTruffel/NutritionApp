"hrv.interpretation.maintain.summary" = "Twoje HRV sugeruje dziś lekkie pobudzenie.";
"hrv.interpretation.maintain.recommendation" = "Możesz działać, ale unikaj kumulowania zbędnego stresu. Umiarkowany trening, spacer, nawodnienie i równe tempo pasują dziś lepiej.";
"hrv.interpretation.recover.summary" = "Twoje wskaźniki regeneracji są dziś obniżone.";
"hrv.interpretation.recover.recommendation" = "Wybierz lżejszy ruch, nawodnienie, mniejszy stres i wcześniejszy sen, jeśli to możliwe.";
"hrv.interpretation.high_hrv_fatigue.summary" = "Twoje HRV jest nietypowo wysokie w porównaniu z punktem odniesienia.";
"hrv.interpretation.high_hrv_fatigue.recommendation" = "Jeśli czujesz zmęczenie, może to odzwierciedlać potrzebę regeneracji. Zachowaj umiarkowany dzień i słuchaj swojego ciała.";
"hrv.interpretation.high_hrv_good.summary" = "Twój sygnał regeneracji jest wyższy niż zwykle.";
"hrv.interpretation.high_hrv_good.recommendation" = "Jeśli czujesz się dobrze, może to być dzień silnej regeneracji.";
"hrv.explanation.amo50_elevated" = "Skupienie uderzeń jest wyższe niż zwykle, co często łączy się z większym pobudzeniem współczulnym.";
"hrv.reminders.no_measurement.title" = "Sprawdzenie HRV";
"hrv.reminders.no_measurement.general.body" = "Brak skanu HRV na dziś. Wykonaj szybki skan, gdy jesteś spokojny, aby dzisiejsze wskazówki były dokładniejsze.";
"hrv.reminders.no_measurement.baseline_building.body" = "Budujesz swój punkt odniesienia HRV. Jeden spokojny skan dziś pomoże aplikacji zrozumieć Twój normalny rytm.";
"hrv.reminders.bad_quality.title" = "Powtórz skan HRV";
"hrv.reminders.bad_quality.body" = "Twój ostatni skan HRV nie był dość czysty dla pewnych wskazówek. Powtórz go w pozycji siedzącej i nieruchomo, gdy masz spokojną chwilę.";
"hrv.reminders.with_measurement.push.title" = "Silny sygnał regeneracji";
"hrv.reminders.with_measurement.push.body" = "Twój sygnał regeneracji wygląda dziś mocno. Dobry dzień na skupioną pracę lub mocniejszy trening, jeśli czujesz się dobrze.";
"hrv.reminders.with_measurement.normal.title" = "Zrównoważone HRV dziś";
"hrv.reminders.with_measurement.normal.body" = "Twoje HRV wygląda dziś na zrównoważone. Trzymaj się zwykłego planu i utrzymuj rytm.";
"hrv.reminders.with_measurement.maintain.title" = "Lekkie pobudzenie dziś";
"hrv.reminders.with_measurement.maintain.body" = "Twoje HRV sugeruje dziś lekkie pobudzenie. Możesz działać, ale unikaj kumulowania zbyt dużego stresu.";
"hrv.reminders.with_measurement.recover.title" = "Dziś najpierw regeneracja";
"hrv.reminders.with_measurement.recover.body" = "Twoje wskaźniki regeneracji są dziś obniżone. Wybierz lżejszy ruch, nawodnienie i wcześniejszy sen, jeśli to możliwe.";
"hrv.reminders.with_measurement.uncertain.title" = "HRV niejasne dziś";
"hrv.reminders.with_measurement.uncertain.body" = "Dzisiejszy skan nie był dość czysty dla mocnych wskazówek. Powtórz go, gdy masz spokojną chwilę.";
"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Zmienność krótkoterminowa";
"hrv.metrics.rmssd.meaning" = "RMSSD odzwierciedla zmiany między kolejnymi uderzeniami, napędzane głównie przez przywspółczulną (regeneracyjną) gałąź układu nerwowego.";
"hrv.metrics.rmssd.low" = "Niższe niż zwykle RMSSD może odzwierciedlać stres, słaby sen, chorobę lub ciężki trening.";
"hrv.metrics.rmssd.high" = "Wyższe RMSSD często odzwierciedla dobrą regenerację, choć nietypowo wysokie wartości przy zmęczeniu mogą oznaczać potrzebę regeneracji.";
"hrv.metrics.rmssd.reliability" = "Wiarygodne nawet na krótkich, spokojnych skanach.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Zmienność ogólna";
"hrv.metrics.sdnn.meaning" = "SDNN ujmuje ogólny rozrzut długości interwałów, odzwierciedlając obie gałęzie układu nerwowego.";
"hrv.metrics.sdnn.low" = "Niższe SDNN może odzwierciedlać zmniejszoną ogólną zdolność adaptacji.";
"hrv.metrics.sdnn.high" = "Wyższe SDNN zwykle odzwierciedla większą ogólną zmienność.";
"hrv.metrics.sdnn.reliability" = "Bardziej wiarygodne na dłuższych skanach.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Udział dużych zmian uderzeń";
"hrv.metrics.pnn50.meaning" = "pNN50 to odsetek sąsiednich uderzeń różniących się o ponad 50 ms, kolejny wskaźnik przywspółczulny.";
"hrv.metrics.pnn50.low" = "Niskie pNN50 może towarzyszyć stresowi lub zmęczeniu.";
"hrv.metrics.pnn50.high" = "Wyższe pNN50 zwykle towarzyszy stanom rozluźnienia i dobrej regeneracji.";
"hrv.metrics.pnn50.reliability" = "Użyteczne na krótkich skanach, ale bardziej zaszumione niż RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Skupienie uderzeń";
"hrv.metrics.amo50.meaning" = "AMo50 opisuje, jak mocno interwały skupiają się wokół najczęstszej wartości; ściślejsze skupienie sugeruje większe pobudzenie współczulne.";
"hrv.metrics.amo50.low" = "Niższe AMo50 sugeruje bardziej rozluźniony, zmienny rytm.";
"hrv.metrics.amo50.high" = "Wyższe AMo50 sugeruje sztywniejszy, bardziej pobudzony rytm.";
"hrv.metrics.amo50.reliability" = "Najlepsze na standardowych lub dłuższych skanach.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Równowaga częstotliwości (tylko kontekst)";
"hrv.metrics.lfhf.meaning" = "LF/HF porównuje moc niskich i wysokich częstotliwości. Łatwo go błędnie odczytać, więc aplikacja traktuje go tylko jako kontekst pomocniczy, nigdy jako prosty miernik stresu.";
"hrv.metrics.lfhf.low" = "Interpretuj ostrożnie; wiele czynników wpływa na ten stosunek.";
"hrv.metrics.lfhf.high" = "Interpretuj ostrożnie; wiele czynników wpływa na ten stosunek.";
"hrv.metrics.lfhf.reliability" = "Wymaga głębokiego skanu i jest wrażliwe na oddech.";
"hrv.metrics.hr.title" = "Tętno";
"hrv.metrics.hr.short" = "Uderzenia na minutę";
"hrv.metrics.hr.meaning" = "Średnie tętno podczas skanu, wyliczone ze średniego czasu między uderzeniami.";
"hrv.metrics.hr.low" = "Niższe tętno spoczynkowe często idzie w parze z dobrą kondycją i regeneracją.";
"hrv.metrics.hr.high" = "Wyższe niż zwykle tętno może odzwierciedlać stres, używki, chorobę lub słabą regenerację.";
"hrv.metrics.hr.reliability" = "Wiarygodne na każdym czystym skanie.";
"hrv.metrics.meannn.title" = "Średnie NN";
"hrv.metrics.meannn.short" = "Średni interwał uderzeń";
"hrv.metrics.meannn.meaning" = "Średni czas między uderzeniami serca w milisekundach. Jest odwrotnością tętna.";
"hrv.metrics.meannn.low" = "Krótsze interwały oznaczają szybsze tętno.";
"hrv.metrics.meannn.high" = "Dłuższe interwały oznaczają wolniejsze tętno.";
"hrv.metrics.meannn.reliability" = "Wiarygodne na każdym czystym skanie.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "RMSSD w skali logarytmicznej";
"hrv.metrics.lnrmssd.meaning" = "Logarytm naturalny z RMSSD. Kompresuje zakres, dzięki czemu łatwiej porównywać trendy z dnia na dzień.";
"hrv.metrics.lnrmssd.low" = "Niższe wartości idą za niższym RMSSD, często stres lub zmęczenie.";
"hrv.metrics.lnrmssd.high" = "Wyższe wartości idą za wyższym RMSSD, często dobra regeneracja.";
"hrv.metrics.lnrmssd.reliability" = "Preferowane do analizy trendów, bo jest stabilniejsze.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Liczba dużych zmian uderzeń";
"hrv.metrics.nn50.meaning" = "Liczba sąsiednich uderzeń różniących się o ponad 50 ms.";
"hrv.metrics.nn50.low" = "Niska liczba może towarzyszyć stresowi lub zmęczeniu.";
"hrv.metrics.nn50.high" = "Wyższa liczba zwykle towarzyszy stanowi rozluźnienia i dobrej regeneracji.";
"hrv.metrics.nn50.reliability" = "Użyteczne na krótkich skanach, ale bardziej zaszumione niż RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Rozrzut zmian między uderzeniami";
"hrv.metrics.sdsd.meaning" = "Odchylenie standardowe różnic między sąsiednimi uderzeniami, miara zmienności krótkoterminowej.";
"hrv.metrics.sdsd.low" = "Niższe SDSD sugeruje zmniejszoną zmienność krótkoterminową.";
"hrv.metrics.sdsd.high" = "Wyższe SDSD sugeruje większą zmienność krótkoterminową, często dobrą regenerację.";
"hrv.metrics.sdsd.reliability" = "Użyteczne na krótkich, spokojnych skanach.";
