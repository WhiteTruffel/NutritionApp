"hrv.onboarding.what_is_hrv.title" = "HRV nedir?";
"hrv.onboarding.what_is_hrv.body" = "HRV, kalp atış hızı değişkenliği anlamına gelir. Kalp atışlarınız arasındaki süredeki küçük değişiklikleri ölçer.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Kalbiniz mükemmel bir metronom gibi atmaz.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Esnek bir ritim, sinir sisteminin daha iyi uyum sağlamasını yansıtabilir.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV uyku, stres, hastalık, antrenman, alkol, kafein, sıvı alımı ve duygusal baskıdan etkilenebilir.";
"hrv.onboarding.camera_scan.title" = "Telefon taraması nasıl çalışır";
"hrv.onboarding.camera_scan.body" = "Kamera, parmak ucunuzdaki küçük renk değişikliklerini görür. Bu değişiklikler nabız dalganızı izler ve uygulama atışlar arasındaki süreyi tahmin eder.";
"hrv.onboarding.camera_scan.bullet_1" = "Bu, kameraya dayalı bir HRV tahminidir.";
"hrv.onboarding.camera_scan.bullet_2" = "Dikkatli ölçüldüğünde eğilimler için yararlıdır.";
"hrv.onboarding.camera_scan.bullet_3" = "Bu EKG değildir ve tıbbi bir teşhis değildir.";
"hrv.onboarding.best_time.title" = "Ne zaman ölçmeli";
"hrv.onboarding.best_time.body" = "En iyi eğilim için her sabah aynı saatte, kafein, yemek, antrenman veya iş stresinden önce ölçün.";
"hrv.onboarding.best_time.bullet_1" = "Uyandıktan sonra ölçün.";
"hrv.onboarding.best_time.bullet_2" = "Kafein veya yemekten önce ölçün.";
"hrv.onboarding.best_time.bullet_3" = "Her gün aynı vücut pozisyonunu kullanın.";
"hrv.onboarding.best_time.bullet_4" = "Aynı sabah zaman aralığında ölçmeye çalışın.";
"hrv.onboarding.preparation.title" = "Başlamadan önce";
"hrv.onboarding.preparation.body" = "Hareketsizlik önemlidir. HRV hassastır, bu yüzden en temiz taramalar vücut sakinken ve parmak sabit kaldığında elde edilir.";
"hrv.onboarding.preparation.bullet_1" = "Oturun veya uzanın.";
"hrv.onboarding.preparation.bullet_2" = "Bir-iki dakika dinlenin.";
"hrv.onboarding.preparation.bullet_3" = "Parmaklarınız soğuksa ellerinizi ısıtın.";
"hrv.onboarding.preparation.bullet_4" = "Normal nefes alın ve konuşmayın.";
"hrv.onboarding.finger_placement.title" = "Parmağınızı nazikçe yerleştirin";
"hrv.onboarding.finger_placement.body" = "Arka kamerayı parmak ucunuzla tamamen kapatın. Hafif, sabit bir baskı uygulayın. Çok sert bastırırsanız kan akışı değişir ve tarama daha az güvenilir olur.";
"hrv.onboarding.finger_placement.bullet_1" = "Kamerayı tamamen kapatın.";
"hrv.onboarding.finger_placement.bullet_2" = "Çok sert bastırmayın.";
