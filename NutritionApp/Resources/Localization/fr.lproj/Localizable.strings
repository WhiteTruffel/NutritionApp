"hrv.onboarding.what_is_hrv.title" = "Qu’est-ce que la VFC ?";
"hrv.onboarding.what_is_hrv.body" = "VFC signifie variabilité de la fréquence cardiaque. Elle mesure de minuscules variations de temps entre vos battements de cœur.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Votre cœur ne bat pas comme un métronome parfait.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Un rythme flexible peut refléter une meilleure adaptabilité du système nerveux.";
"hrv.onboarding.what_is_hrv.bullet_3" = "La VFC peut être influencée par le sommeil, le stress, la maladie, l’entraînement, l’alcool, la caféine, l’hydratation et la pression émotionnelle.";
"hrv.onboarding.camera_scan.title" = "Comment fonctionne le scan du téléphone";
"hrv.onboarding.camera_scan.body" = "La caméra détecte de minuscules changements de couleur au bout de votre doigt. Ces changements suivent votre onde de pouls, et l’application estime le temps entre les battements.";
"hrv.onboarding.camera_scan.bullet_1" = "Il s’agit d’une estimation de la VFC basée sur la caméra.";
"hrv.onboarding.camera_scan.bullet_2" = "C’est utile pour les tendances lorsque la mesure est soignée.";
"hrv.onboarding.camera_scan.bullet_3" = "Ce n’est pas un ECG ni un diagnostic médical.";
"hrv.onboarding.best_time.title" = "Quand mesurer";
"hrv.onboarding.best_time.body" = "Pour la meilleure tendance, mesurez à la même heure chaque matin avant la caféine, la nourriture, l’entraînement ou le stress du travail.";
"hrv.onboarding.best_time.bullet_1" = "Mesurez après le réveil.";
"hrv.onboarding.best_time.bullet_2" = "Mesurez avant la caféine ou la nourriture.";
"hrv.onboarding.best_time.bullet_3" = "Utilisez la même position du corps chaque jour.";
"hrv.onboarding.best_time.bullet_4" = "Essayez de mesurer dans le même créneau horaire le matin.";
"hrv.onboarding.preparation.title" = "Avant de commencer";
"hrv.onboarding.preparation.body" = "L’immobilité compte. La VFC est sensible, les scans les plus nets se produisent donc lorsque votre corps est calme et que votre doigt reste stable.";
"hrv.onboarding.preparation.bullet_1" = "Asseyez-vous ou allongez-vous.";
"hrv.onboarding.preparation.bullet_2" = "Reposez-vous une à deux minutes.";
"hrv.onboarding.preparation.bullet_3" = "Réchauffez vos mains si vos doigts sont froids.";
"hrv.onboarding.preparation.bullet_4" = "Respirez normalement et évitez de parler.";
"hrv.onboarding.finger_placement.title" = "Placez votre doigt délicatement";
"hrv.onboarding.finger_placement.body" = "Couvrez entièrement la caméra arrière avec le bout de votre doigt. Exercez une pression douce et constante. Si vous appuyez trop fort, la circulation sanguine change et le scan devient moins fiable.";
"hrv.onboarding.finger_placement.bullet_1" = "Couvrez entièrement la caméra.";
"hrv.onboarding.finger_placement.bullet_2" = "N’appuyez pas trop fort.";
"hrv.onboarding.finger_placement.bullet_3" = "Gardez votre doigt immobile.";
"hrv.onboarding.during_scan.title" = "Pendant le scan";
"hrv.onboarding.during_scan.body" = "Respirez simplement normalement. N’essayez pas d’améliorer le score. Le but est de capturer votre état réel.";
"hrv.onboarding.during_scan.bullet_1" = "Restez immobile.";
"hrv.onboarding.during_scan.bullet_2" = "Ne parlez pas.";
"hrv.onboarding.during_scan.bullet_3" = "Continuez à respirer naturellement.";
"hrv.onboarding.scan_length.title" = "Choisissez la profondeur du scan";
"hrv.onboarding.scan_length.body" = "Les scans courts sont utiles pour les tendances quotidiennes. Les scans plus longs débloquent des mesures de VFC plus approfondies.";
"hrv.onboarding.scan_length.bullet_1" = "Scan rapide : 60 à 120 secondes pour la forme du jour.";
"hrv.onboarding.scan_length.bullet_2" = "Scan standard : 5 minutes pour une analyse plus approfondie.";
"hrv.onboarding.scan_length.bullet_3" = "Scan approfondi : 300 battements nets ou plus pour des mesures de VFC avancées.";
"hrv.onboarding.results.title" = "Comment lire votre résultat";
"hrv.onboarding.results.body" = "Un scan est un instantané. Votre tendance personnelle est plus importante qu’une valeur isolée.";
"hrv.onboarding.results.bullet_1" = "Votre référence personnelle compte plus qu’une plage générique.";
"hrv.onboarding.results.bullet_2" = "Une VFC basse peut refléter le stress, un mauvais sommeil, la maladie, la déshydratation, l’alcool ou un entraînement intense.";
"hrv.onboarding.results.bullet_3" = "Une VFC élevée peut signifier une bonne récupération, mais si vous vous sentez épuisé, elle peut aussi refléter un besoin de récupération.";
"hrv.onboarding.daily_guidance.title" = "Vos conseils quotidiens";
"hrv.onboarding.daily_guidance.body" = "L’application utilise votre tendance de VFC pour rendre les rappels quotidiens plus personnels.";
"hrv.onboarding.daily_guidance.bullet_1" = "Si vous avez mesuré aujourd’hui, les rappels peuvent inclure des conseils basés sur la VFC.";
"hrv.onboarding.daily_guidance.bullet_2" = "Si vous n’avez pas mesuré, les rappels vous inciteront doucement à faire un scan.";
"hrv.onboarding.daily_guidance.bullet_3" = "Plus vous mesurez régulièrement, meilleurs sont vos conseils.";
"hrv.onboarding.limitations.title" = "Limites importantes";
"hrv.onboarding.limitations.body" = "La VFC n’est pas un diagnostic médical. Cette application ne détecte pas les maladies cardiaques, les arythmies ni les urgences médicales.";
"hrv.onboarding.limitations.bullet_1" = "La VFC par caméra est une estimation, pas un ECG.";
"hrv.onboarding.limitations.bullet_2" = "Les mouvements, les doigts froids, la pression, les médicaments et les arythmies peuvent affecter la précision.";
"hrv.onboarding.limitations.bullet_3" = "Si vous ressentez une douleur thoracique, des malaises, un essoufflement sévère ou des symptômes inhabituels, consultez un médecin.";
"hrv.onboarding.first_scan.title" = "Prêt pour votre premier scan ?";
"hrv.onboarding.first_scan.body" = "Faites votre premier scan au calme maintenant pour que l’application commence à établir votre référence personnelle de VFC.";
"hrv.onboarding.first_scan.primary_cta" = "Démarrer le scan VFC";
"hrv.onboarding.first_scan.secondary_cta" = "Me le rappeler plus tard";
