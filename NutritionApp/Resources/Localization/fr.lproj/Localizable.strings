"hrv.reminders.with_measurement.normal.title" = "VFC équilibrée aujourd’hui";
"hrv.reminders.with_measurement.normal.body" = "Votre VFC semble équilibrée aujourd’hui. Gardez votre plan habituel et maintenez votre rythme.";
"hrv.reminders.with_measurement.maintain.title" = "Légère activation aujourd’hui";
"hrv.reminders.with_measurement.maintain.body" = "Votre VFC suggère une légère activation aujourd’hui. Vous pouvez être performant, mais évitez d’accumuler trop de stress.";
"hrv.reminders.with_measurement.recover.title" = "Priorité à la récupération aujourd’hui";
