"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Variabilité à court terme";
"hrv.metrics.rmssd.meaning" = "Le RMSSD reflète les variations battement par battement, principalement dues à la branche parasympathique (de récupération) de votre système nerveux.";
"hrv.metrics.rmssd.low" = "Un RMSSD plus bas que d’habitude peut refléter le stress, un mauvais sommeil, la maladie ou un entraînement intense.";
"hrv.metrics.rmssd.high" = "Un RMSSD plus élevé reflète souvent une bonne récupération, mais des valeurs anormalement élevées avec de la fatigue peuvent indiquer un besoin de récupération.";
"hrv.metrics.rmssd.reliability" = "Fiable même sur des scans courts et au calme.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Variabilité globale";
"hrv.metrics.sdnn.meaning" = "Le SDNN capture la dispersion globale de la longueur de vos intervalles, reflétant les deux branches de votre système nerveux.";
"hrv.metrics.sdnn.low" = "Un SDNN plus bas peut refléter une adaptabilité globale réduite.";
"hrv.metrics.sdnn.high" = "Un SDNN plus élevé reflète généralement une plus grande variabilité globale.";
"hrv.metrics.sdnn.reliability" = "Plus fiable sur les scans plus longs.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Part des grands écarts entre battements";
"hrv.metrics.pnn50.meaning" = "Le pNN50 est le pourcentage de battements adjacents qui diffèrent de plus de 50 ms, un autre marqueur parasympathique.";
"hrv.metrics.pnn50.low" = "Un pNN50 bas peut accompagner le stress ou la fatigue.";
"hrv.metrics.pnn50.high" = "Un pNN50 plus élevé accompagne généralement des états détendus et bien récupérés.";
"hrv.metrics.pnn50.reliability" = "Utilisable sur des scans courts, mais plus bruité que le RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Regroupement des battements";
"hrv.metrics.amo50.meaning" = "L’AMo50 décrit à quel point vos intervalles se regroupent autour de la valeur la plus fréquente ; un regroupement plus serré suggère une activation sympathique accrue.";
"hrv.metrics.amo50.low" = "Un AMo50 plus bas suggère un rythme plus détendu et variable.";
"hrv.metrics.amo50.high" = "Un AMo50 plus élevé suggère un rythme plus rigide et plus activé.";
"hrv.metrics.amo50.reliability" = "Optimal sur des scans standard ou plus longs.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Équilibre des fréquences (contexte uniquement)";
"hrv.metrics.lfhf.meaning" = "Le LF/HF compare la puissance des basses et hautes fréquences. Il est facile à mal interpréter, cette application le traite donc uniquement comme un contexte complémentaire, jamais comme un simple indicateur de stress.";
"hrv.metrics.lfhf.low" = "À interpréter avec prudence ; de nombreux facteurs influencent ce ratio.";
"hrv.metrics.lfhf.high" = "À interpréter avec prudence ; de nombreux facteurs influencent ce ratio.";
"hrv.metrics.lfhf.reliability" = "Nécessite un scan approfondi et est sensible à la respiration.";
"hrv.metrics.hr.title" = "Fréquence cardiaque";
"hrv.metrics.hr.short" = "Battements par minute";
"hrv.metrics.hr.meaning" = "Fréquence cardiaque moyenne pendant le scan, dérivée du temps moyen entre les battements.";
"hrv.metrics.hr.low" = "Une fréquence cardiaque au repos plus basse va souvent de pair avec une bonne condition physique et une bonne récupération.";
"hrv.metrics.hr.high" = "Une fréquence cardiaque plus élevée que d’habitude peut refléter le stress, des stimulants, la maladie ou une mauvaise récupération.";
"hrv.metrics.hr.reliability" = "Fiable sur tout scan net.";
"hrv.metrics.meannn.title" = "NN moyen";
"hrv.metrics.meannn.short" = "Intervalle moyen entre battements";
"hrv.metrics.meannn.meaning" = "Le temps moyen entre les battements en millisecondes. C’est l’inverse de la fréquence cardiaque.";
"hrv.metrics.meannn.low" = "Des intervalles plus courts signifient une fréquence cardiaque plus rapide.";
"hrv.metrics.meannn.high" = "Des intervalles plus longs signifient une fréquence cardiaque plus lente.";
"hrv.metrics.meannn.reliability" = "Fiable sur tout scan net.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "RMSSD à l’échelle logarithmique";
"hrv.metrics.lnrmssd.meaning" = "Le logarithme naturel du RMSSD. Il compresse la plage pour faciliter la comparaison des tendances au jour le jour.";
"hrv.metrics.lnrmssd.low" = "Des valeurs plus basses suivent un RMSSD plus bas, souvent du stress ou de la fatigue.";
"hrv.metrics.lnrmssd.high" = "Des valeurs plus élevées suivent un RMSSD plus élevé, souvent une bonne récupération.";
"hrv.metrics.lnrmssd.reliability" = "Privilégié pour l’analyse des tendances car plus stable.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Nombre de grands écarts entre battements";
"hrv.metrics.nn50.meaning" = "Le nombre de battements adjacents qui diffèrent de plus de 50 ms.";
"hrv.metrics.nn50.low" = "Un nombre faible peut accompagner le stress ou la fatigue.";
"hrv.metrics.nn50.high" = "Un nombre plus élevé accompagne généralement un état détendu et bien récupéré.";
"hrv.metrics.nn50.reliability" = "Utilisable sur des scans courts, mais plus bruité que le RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Dispersion des écarts entre battements";
"hrv.metrics.sdsd.meaning" = "L’écart-type des différences entre battements adjacents, une mesure de variabilité à court terme.";
"hrv.metrics.sdsd.low" = "Un SDSD plus bas suggère une variabilité à court terme réduite.";
"hrv.metrics.sdsd.high" = "Un SDSD plus élevé suggère plus de variabilité à court terme, souvent une bonne récupération.";
"hrv.metrics.sdsd.reliability" = "Utilisable sur des scans courts et au calme.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Variabilité globale relative";
"hrv.metrics.cvnn.meaning" = "Le SDNN divisé par l’intervalle moyen, la variabilité est donc exprimée par rapport à la fréquence cardiaque.";
"hrv.metrics.cvnn.low" = "Un CVNN plus bas suggère une variabilité relative réduite.";
"hrv.metrics.cvnn.high" = "Un CVNN plus élevé suggère une plus grande variabilité relative.";
"hrv.metrics.cvnn.reliability" = "Plus fiable sur les scans plus longs.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Variabilité à court terme relative";
"hrv.metrics.cvsd.meaning" = "Le RMSSD divisé par l’intervalle moyen, la variabilité à court terme par rapport à la fréquence cardiaque.";
"hrv.metrics.cvsd.low" = "Un CVSD plus bas suggère une variabilité à court terme relative réduite.";
"hrv.metrics.cvsd.high" = "Un CVSD plus élevé suggère plus de variabilité à court terme relative.";
"hrv.metrics.cvsd.reliability" = "Utilisable sur des scans courts.";
"hrv.metrics.modenn.title" = "NN modal";
"hrv.metrics.modenn.short" = "Intervalle entre battements le plus fréquent";
"hrv.metrics.modenn.meaning" = "La longueur d’intervalle la plus fréquente, le centre de la barre la plus haute de l’histogramme.";
"hrv.metrics.modenn.low" = "Un mode plus court signifie une fréquence cardiaque typique plus rapide.";
"hrv.metrics.modenn.high" = "Un mode plus long signifie une fréquence cardiaque typique plus lente.";
"hrv.metrics.modenn.reliability" = "Optimal sur des scans standard ou plus longs.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Étendue des intervalles";
"hrv.metrics.mxdmn.meaning" = "La différence entre l’intervalle le plus long et le plus court du scan.";
"hrv.metrics.mxdmn.low" = "Une faible étendue suggère un rythme stable.";
"hrv.metrics.mxdmn.high" = "Une grande étendue peut refléter une forte variabilité ou des artefacts.";
"hrv.metrics.mxdmn.reliability" = "Sensible aux valeurs aberrantes isolées, à interpréter avec soin.";
"hrv.metrics.triangularindex.title" = "Indice triangulaire";
"hrv.metrics.triangularindex.short" = "Variabilité globale géométrique";
"hrv.metrics.triangularindex.meaning" = "Le nombre total d’intervalles divisé par la hauteur du pic de l’histogramme, une mesure géométrique de la variabilité globale.";
"hrv.metrics.triangularindex.low" = "Des valeurs plus basses suggèrent une variabilité globale réduite.";
"hrv.metrics.triangularindex.high" = "Des valeurs plus élevées suggèrent une plus grande variabilité globale.";
"hrv.metrics.triangularindex.reliability" = "Nécessite au moins quelques minutes de battements.";
"hrv.metrics.tinn.title" = "TINN";
"hrv.metrics.tinn.short" = "Largeur de base de l’histogramme";
"hrv.metrics.tinn.meaning" = "La largeur de base de l’histogramme des intervalles, une autre mesure géométrique de la variabilité globale.";
