"hrv.onboarding.what_is_hrv.title" = "Che cos’è la VFC?";
"hrv.onboarding.what_is_hrv.body" = "VFC significa variabilità della frequenza cardiaca. Misura minuscole variazioni di tempo tra i tuoi battiti.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Il tuo cuore non batte come un metronomo perfetto.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Un ritmo flessibile può riflettere una migliore adattabilità del sistema nervoso.";
"hrv.onboarding.what_is_hrv.bullet_3" = "La VFC può essere influenzata da sonno, stress, malattia, allenamento, alcol, caffeina, idratazione e pressione emotiva.";
"hrv.onboarding.camera_scan.title" = "Come funziona la scansione del telefono";
"hrv.onboarding.camera_scan.body" = "La fotocamera rileva minuscoli cambiamenti di colore sul polpastrello. Questi cambiamenti seguono l’onda del polso, e l’app stima il tempo tra i battiti.";
"hrv.onboarding.camera_scan.bullet_1" = "È una stima della VFC basata sulla fotocamera.";
"hrv.onboarding.camera_scan.bullet_2" = "È utile per le tendenze quando la misurazione è accurata.";
"hrv.onboarding.camera_scan.bullet_3" = "Non è un ECG né una diagnosi medica.";
"hrv.onboarding.best_time.title" = "Quando misurare";
"hrv.onboarding.best_time.body" = "Per la tendenza migliore, misura alla stessa ora ogni mattina prima di caffeina, cibo, allenamento o stress da lavoro.";
"hrv.onboarding.best_time.bullet_1" = "Misura dopo il risveglio.";
"hrv.onboarding.best_time.bullet_2" = "Misura prima di caffeina o cibo.";
"hrv.onboarding.best_time.bullet_3" = "Usa la stessa posizione del corpo ogni giorno.";
"hrv.onboarding.best_time.bullet_4" = "Cerca di misurare nella stessa fascia oraria del mattino.";
"hrv.onboarding.preparation.title" = "Prima di iniziare";
"hrv.onboarding.preparation.body" = "L’immobilità conta. La VFC è sensibile, quindi le scansioni più pulite avvengono quando il corpo è calmo e il dito resta fermo.";
"hrv.onboarding.preparation.bullet_1" = "Siediti o sdraiati.";
"hrv.onboarding.preparation.bullet_2" = "Riposa da uno a due minuti.";
"hrv.onboarding.preparation.bullet_3" = "Scalda le mani se hai le dita fredde.";
"hrv.onboarding.preparation.bullet_4" = "Respira normalmente ed evita di parlare.";
"hrv.onboarding.finger_placement.title" = "Posiziona il dito con delicatezza";
"hrv.onboarding.finger_placement.body" = "Copri completamente la fotocamera posteriore con il polpastrello. Applica una pressione delicata e costante. Se premi troppo forte, il flusso sanguigno cambia e la scansione diventa meno affidabile.";
"hrv.onboarding.finger_placement.bullet_1" = "Copri completamente la fotocamera.";
"hrv.onboarding.finger_placement.bullet_2" = "Non premere troppo forte.";
"hrv.onboarding.finger_placement.bullet_3" = "Tieni il dito fermo.";
"hrv.onboarding.during_scan.title" = "Durante la scansione";
"hrv.onboarding.during_scan.body" = "Respira semplicemente in modo normale. Non cercare di migliorare il punteggio. L’obiettivo è catturare il tuo stato reale.";
"hrv.onboarding.during_scan.bullet_1" = "Resta fermo.";
"hrv.onboarding.during_scan.bullet_2" = "Non parlare.";
"hrv.onboarding.during_scan.bullet_3" = "Continua a respirare in modo naturale.";
"hrv.onboarding.scan_length.title" = "Scegli la profondità della scansione";
"hrv.onboarding.scan_length.body" = "Le scansioni brevi sono utili per le tendenze quotidiane. Le scansioni più lunghe sbloccano metriche di VFC più approfondite.";
"hrv.onboarding.scan_length.bullet_1" = "Scansione rapida: da 60 a 120 secondi per la prontezza quotidiana.";
"hrv.onboarding.scan_length.bullet_2" = "Scansione standard: 5 minuti per un’analisi più approfondita.";
"hrv.onboarding.scan_length.bullet_3" = "Scansione approfondita: 300 battiti puliti o più per metriche di VFC avanzate.";
"hrv.onboarding.results.title" = "Come leggere il tuo risultato";
"hrv.onboarding.results.body" = "Una scansione è un’istantanea. La tua tendenza personale è più importante di un singolo valore isolato.";
"hrv.onboarding.results.bullet_1" = "Il tuo riferimento personale conta più di un intervallo generico.";
"hrv.onboarding.results.bullet_2" = "Una VFC bassa può riflettere stress, sonno scarso, malattia, disidratazione, alcol o allenamento intenso.";
"hrv.onboarding.results.bullet_3" = "Una VFC alta può indicare un buon recupero, ma se ti senti esausto può anche riflettere un bisogno di recupero.";
"hrv.onboarding.daily_guidance.title" = "I tuoi consigli quotidiani";
"hrv.onboarding.daily_guidance.body" = "L’app usa la tua tendenza di VFC per rendere più personali i promemoria quotidiani.";
"hrv.onboarding.daily_guidance.bullet_1" = "Se hai misurato oggi, i promemoria possono includere consigli basati sulla VFC.";
"hrv.onboarding.daily_guidance.bullet_2" = "Se non hai misurato, i promemoria ti inviteranno con gentilezza a fare una scansione.";
"hrv.onboarding.daily_guidance.bullet_3" = "Più misuri con costanza, migliori diventano i tuoi consigli.";
"hrv.onboarding.limitations.title" = "Limitazioni importanti";
"hrv.onboarding.limitations.body" = "La VFC non è una diagnosi medica. Questa app non rileva malattie cardiache, aritmie né emergenze mediche.";
"hrv.onboarding.limitations.bullet_1" = "La VFC da fotocamera è una stima, non un ECG.";
"hrv.onboarding.limitations.bullet_2" = "Movimento, dita fredde, pressione, farmaci e aritmie possono influire sulla precisione.";
"hrv.onboarding.limitations.bullet_3" = "Se avverti dolore al petto, svenimenti, grave mancanza di respiro o sintomi insoliti, cerca aiuto medico.";
"hrv.onboarding.first_scan.title" = "Pronto per la tua prima scansione?";
"hrv.onboarding.first_scan.body" = "Fai ora la tua prima scansione in calma così l’app può iniziare a costruire il tuo riferimento personale di VFC.";
"hrv.onboarding.first_scan.primary_cta" = "Avvia scansione VFC";
"hrv.onboarding.first_scan.secondary_cta" = "Ricordamelo più tardi";
