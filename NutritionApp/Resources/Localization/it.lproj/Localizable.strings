"hrv.interpretation.baseline.none.summary" = "Il tuo riferimento di VFC è ancora in costruzione.";
"hrv.interpretation.baseline.none.recommendation" = "Continua a misurare alla stessa ora ogni mattina. Dopo qualche altra scansione, i tuoi consigli diventeranno più personali.";
"hrv.interpretation.push.summary" = "Il tuo segnale di recupero sembra forte oggi.";
"hrv.interpretation.push.recommendation" = "Può essere una buona giornata per allenarti, concentrarti o portare avanti un lavoro importante se ti senti bene.";
"hrv.interpretation.normal.summary" = "La tua VFC sembra equilibrata oggi.";
"hrv.interpretation.normal.recommendation" = "Mantieni il tuo piano abituale e conserva il tuo ritmo.";
"hrv.interpretation.maintain.summary" = "La tua VFC suggerisce una lieve attivazione oggi.";
"hrv.interpretation.maintain.recommendation" = "Puoi rendere, ma evita di accumulare stress inutile. Oggi si adattano meglio un allenamento moderato, camminare, l’idratazione e un ritmo costante.";
"hrv.interpretation.recover.summary" = "I tuoi marcatori di recupero sono ridotti oggi.";
"hrv.interpretation.recover.recommendation" = "Scegli un movimento più leggero, l’idratazione, meno stress e una serata più presto a letto se possibile.";
"hrv.interpretation.high_hrv_fatigue.summary" = "La tua VFC è insolitamente alta rispetto al tuo riferimento.";
"hrv.interpretation.high_hrv_fatigue.recommendation" = "Se ti senti stanco, questo può riflettere un bisogno di recupero. Mantieni la giornata moderata e ascolta il tuo corpo.";
"hrv.interpretation.high_hrv_good.summary" = "Il tuo segnale di recupero è più alto del solito.";
"hrv.interpretation.high_hrv_good.recommendation" = "Se ti senti bene, questa può essere una buona giornata di recupero.";
"hrv.explanation.amo50_elevated" = "Il raggruppamento battito per battito è più alto del solito, cosa che spesso si accompagna a una maggiore attivazione simpatica.";
"hrv.reminders.no_measurement.title" = "Controllo VFC";
"hrv.reminders.no_measurement.general.body" = "Ancora nessuna scansione VFC oggi. Fai una scansione rapida quando sei in calma così i consigli di oggi sono più precisi.";
"hrv.reminders.no_measurement.baseline_building.body" = "Stai costruendo il tuo riferimento di VFC. Una scansione in calma oggi aiuta l’app a capire il tuo ritmo normale.";
"hrv.reminders.bad_quality.title" = "Ripeti la scansione VFC";
"hrv.reminders.bad_quality.body" = "La tua ultima scansione VFC non era abbastanza chiara per consigli affidabili. Ripetila da seduto e fermo quando hai un minuto di calma.";
"hrv.reminders.with_measurement.push.title" = "Segnale di recupero forte";
"hrv.reminders.with_measurement.push.body" = "Il tuo segnale di recupero sembra forte oggi. Buona giornata per un lavoro concentrato o un allenamento più intenso se ti senti bene.";
"hrv.reminders.with_measurement.normal.title" = "VFC equilibrata oggi";
"hrv.reminders.with_measurement.normal.body" = "La tua VFC sembra equilibrata oggi. Mantieni il tuo piano abituale e conserva il tuo ritmo.";
"hrv.reminders.with_measurement.maintain.title" = "Lieve attivazione oggi";
"hrv.reminders.with_measurement.maintain.body" = "La tua VFC suggerisce una lieve attivazione oggi. Puoi rendere, ma evita di accumulare troppo stress.";
"hrv.reminders.with_measurement.recover.title" = "Oggi prima il recupero";
"hrv.reminders.with_measurement.recover.body" = "I tuoi marcatori di recupero sono ridotti oggi. Scegli un movimento più leggero, l’idratazione e una serata più presto a letto se possibile.";
"hrv.reminders.with_measurement.uncertain.title" = "VFC poco chiara oggi";
"hrv.reminders.with_measurement.uncertain.body" = "La scansione di oggi non era abbastanza chiara per buoni consigli. Ripetila quando hai un minuto di calma.";
"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Variabilità a breve termine";
"hrv.metrics.rmssd.meaning" = "Il RMSSD riflette i cambiamenti battito per battito, guidati principalmente dal ramo parasimpatico (di recupero) del tuo sistema nervoso.";
"hrv.metrics.rmssd.low" = "Un RMSSD più basso del solito può riflettere stress, sonno scarso, malattia o allenamento intenso.";
"hrv.metrics.rmssd.high" = "Un RMSSD più alto riflette spesso un buon recupero, anche se valori insolitamente alti con stanchezza possono indicare un bisogno di recupero.";
"hrv.metrics.rmssd.reliability" = "Affidabile anche su scansioni brevi e in calma.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Variabilità complessiva";
"hrv.metrics.sdnn.meaning" = "Il SDNN cattura la dispersione complessiva della durata dei tuoi intervalli, riflettendo entrambi i rami del tuo sistema nervoso.";
"hrv.metrics.sdnn.low" = "Un SDNN più basso può riflettere una ridotta adattabilità complessiva.";
"hrv.metrics.sdnn.high" = "Un SDNN più alto riflette in genere una maggiore variabilità complessiva.";
"hrv.metrics.sdnn.reliability" = "Più affidabile su scansioni più lunghe.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Quota di grandi variazioni tra battiti";
"hrv.metrics.pnn50.meaning" = "Il pNN50 è la percentuale di battiti adiacenti che differiscono di più di 50 ms, un altro marcatore parasimpatico.";
"hrv.metrics.pnn50.low" = "Un pNN50 basso può accompagnare stress o stanchezza.";
"hrv.metrics.pnn50.high" = "Un pNN50 più alto accompagna di solito stati rilassati e ben recuperati.";
"hrv.metrics.pnn50.reliability" = "Utilizzabile su scansioni brevi, ma più rumoroso del RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Raggruppamento dei battiti";
"hrv.metrics.amo50.meaning" = "L’AMo50 descrive quanto strettamente i tuoi intervalli si raggruppano attorno al valore più frequente; un raggruppamento più stretto suggerisce una maggiore attivazione simpatica.";
"hrv.metrics.amo50.low" = "Un AMo50 più basso suggerisce un ritmo più rilassato e variabile.";
"hrv.metrics.amo50.high" = "Un AMo50 più alto suggerisce un ritmo più rigido e attivato.";
"hrv.metrics.amo50.reliability" = "Migliore su scansioni standard o più lunghe.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Equilibrio delle frequenze (solo contesto)";
"hrv.metrics.lfhf.meaning" = "Il LF/HF confronta la potenza delle basse e alte frequenze. È facile da interpretare male, quindi questa app lo tratta solo come contesto di supporto, mai come un semplice misuratore di stress.";
"hrv.metrics.lfhf.low" = "Interpreta con cautela; molti fattori muovono questo rapporto.";
"hrv.metrics.lfhf.high" = "Interpreta con cautela; molti fattori muovono questo rapporto.";
"hrv.metrics.lfhf.reliability" = "Richiede una scansione approfondita ed è sensibile alla respirazione.";
"hrv.metrics.hr.title" = "Frequenza cardiaca";
"hrv.metrics.hr.short" = "Battiti al minuto";
"hrv.metrics.hr.meaning" = "Frequenza cardiaca media durante la scansione, derivata dal tempo medio tra i battiti.";
"hrv.metrics.hr.low" = "Una frequenza cardiaca a riposo più bassa si accompagna spesso a una buona forma fisica e a un buon recupero.";
"hrv.metrics.hr.high" = "Una frequenza cardiaca più alta del solito può riflettere stress, stimolanti, malattia o scarso recupero.";
"hrv.metrics.hr.reliability" = "Affidabile su qualsiasi scansione pulita.";
"hrv.metrics.meannn.title" = "NN medio";
"hrv.metrics.meannn.short" = "Intervallo medio tra battiti";
"hrv.metrics.meannn.meaning" = "Il tempo medio tra i battiti in millisecondi. È l’inverso della frequenza cardiaca.";
"hrv.metrics.meannn.low" = "Intervalli più brevi indicano una frequenza cardiaca più rapida.";
"hrv.metrics.meannn.high" = "Intervalli più lunghi indicano una frequenza cardiaca più lenta.";
"hrv.metrics.meannn.reliability" = "Affidabile su qualsiasi scansione pulita.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "RMSSD in scala logaritmica";
"hrv.metrics.lnrmssd.meaning" = "Il logaritmo naturale del RMSSD. Comprime l’intervallo così le tendenze giorno per giorno sono più facili da confrontare.";
"hrv.metrics.lnrmssd.low" = "Valori più bassi seguono un RMSSD più basso, spesso stress o stanchezza.";
"hrv.metrics.lnrmssd.high" = "Valori più alti seguono un RMSSD più alto, spesso un buon recupero.";
"hrv.metrics.lnrmssd.reliability" = "Preferito per l’analisi delle tendenze perché più stabile.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Conteggio di grandi variazioni tra battiti";
"hrv.metrics.nn50.meaning" = "Il numero di battiti adiacenti che differiscono di più di 50 ms.";
"hrv.metrics.nn50.low" = "Un conteggio basso può accompagnare stress o stanchezza.";
"hrv.metrics.nn50.high" = "Un conteggio più alto accompagna di solito uno stato rilassato e ben recuperato.";
"hrv.metrics.nn50.reliability" = "Utilizzabile su scansioni brevi, ma più rumoroso del RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Dispersione delle variazioni tra battiti";
"hrv.metrics.sdsd.meaning" = "La deviazione standard delle differenze tra battiti adiacenti, una misura di variabilità a breve termine.";
"hrv.metrics.sdsd.low" = "Un SDSD più basso suggerisce una variabilità a breve termine ridotta.";
"hrv.metrics.sdsd.high" = "Un SDSD più alto suggerisce più variabilità a breve termine, spesso un buon recupero.";
"hrv.metrics.sdsd.reliability" = "Utilizzabile su scansioni brevi e in calma.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Variabilità complessiva relativa";
"hrv.metrics.cvnn.meaning" = "Il SDNN diviso per l’intervallo medio, così la variabilità è espressa in rapporto alla frequenza cardiaca.";
"hrv.metrics.cvnn.low" = "Un CVNN più basso suggerisce una variabilità relativa ridotta.";
"hrv.metrics.cvnn.high" = "Un CVNN più alto suggerisce una maggiore variabilità relativa.";
"hrv.metrics.cvnn.reliability" = "Più affidabile su scansioni più lunghe.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Variabilità a breve termine relativa";
"hrv.metrics.cvsd.meaning" = "Il RMSSD diviso per l’intervallo medio, la variabilità a breve termine in rapporto alla frequenza cardiaca.";
"hrv.metrics.cvsd.low" = "Un CVSD più basso suggerisce una variabilità a breve termine relativa ridotta.";
"hrv.metrics.cvsd.high" = "Un CVSD più alto suggerisce più variabilità a breve termine relativa.";
"hrv.metrics.cvsd.reliability" = "Utilizzabile su scansioni brevi.";
"hrv.metrics.modenn.title" = "NN modale";
"hrv.metrics.modenn.short" = "Intervallo tra battiti più frequente";
"hrv.metrics.modenn.meaning" = "La durata di intervallo più frequente, il centro della barra più alta dell’istogramma.";
"hrv.metrics.modenn.low" = "Una moda più breve indica una frequenza cardiaca tipica più rapida.";
"hrv.metrics.modenn.high" = "Una moda più lunga indica una frequenza cardiaca tipica più lenta.";
"hrv.metrics.modenn.reliability" = "Migliore su scansioni standard o più lunghe.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Intervallo di variazione";
"hrv.metrics.mxdmn.meaning" = "La differenza tra l’intervallo più lungo e quello più breve della scansione.";
"hrv.metrics.mxdmn.low" = "Un intervallo piccolo suggerisce un ritmo stabile.";
"hrv.metrics.mxdmn.high" = "Un intervallo grande può riflettere un’alta variabilità o artefatti.";
"hrv.metrics.mxdmn.reliability" = "Sensibile a singoli valori anomali, interpretalo con attenzione.";
"hrv.metrics.triangularindex.title" = "Indice triangolare";
"hrv.metrics.triangularindex.short" = "Variabilità complessiva geometrica";
"hrv.metrics.triangularindex.meaning" = "Il numero totale di intervalli diviso per l’altezza del picco dell’istogramma, una misura geometrica della variabilità complessiva.";
"hrv.metrics.triangularindex.low" = "Valori più bassi suggeriscono una variabilità complessiva ridotta.";
"hrv.metrics.triangularindex.high" = "Valori più alti suggeriscono una maggiore variabilità complessiva.";
"hrv.metrics.triangularindex.reliability" = "Richiede almeno qualche minuto di battiti.";
"hrv.metrics.tinn.title" = "TINN";
"hrv.metrics.tinn.short" = "Larghezza di base dell’istogramma";
"hrv.metrics.tinn.meaning" = "La larghezza di base dell’istogramma degli intervalli, un’altra misura geometrica della variabilità complessiva.";
"hrv.metrics.tinn.low" = "Valori più bassi suggeriscono una variabilità complessiva ridotta.";
"hrv.metrics.tinn.high" = "Valori più alti suggeriscono una maggiore variabilità complessiva.";
"hrv.metrics.tinn.reliability" = "Richiede una scansione più lunga; mostrato solo quando può essere stimato in modo affidabile.";
"hrv.metrics.hfpower.title" = "Potenza HF";
"hrv.metrics.hfpower.short" = "Potenza delle alte frequenze";
"hrv.metrics.hfpower.meaning" = "La potenza nella banda delle alte frequenze, legata principalmente alla respirazione e all’attività parasimpatica.";
"hrv.metrics.hfpower.low" = "Una HF più bassa può accompagnare stress o respirazione superficiale.";
"hrv.metrics.hfpower.high" = "Una HF più alta accompagna spesso una respirazione calma e rilassata.";
"hrv.metrics.hfpower.reliability" = "Richiede una scansione approfondita e una respirazione costante.";
"hrv.metrics.lfpower.title" = "Potenza LF";
"hrv.metrics.lfpower.short" = "Potenza delle basse frequenze";
"hrv.metrics.lfpower.meaning" = "La potenza nella banda delle basse frequenze, influenzata da entrambi i rami del sistema nervoso e dalla regolazione della pressione sanguigna.";
"hrv.metrics.lfpower.low" = "Interpreta con attenzione; molti fattori muovono questo valore.";
"hrv.metrics.lfpower.high" = "Interpreta con attenzione; molti fattori muovono questo valore.";
"hrv.metrics.lfpower.reliability" = "Richiede una scansione approfondita.";
"hrv.metrics.vlfpower.title" = "Potenza VLF";
"hrv.metrics.vlfpower.short" = "Potenza delle frequenze molto basse";
"hrv.metrics.vlfpower.meaning" = "La potenza nella banda delle frequenze molto basse, legata a processi di regolazione più lenti.";
"hrv.metrics.vlfpower.low" = "Una VLF più bassa si osserva a volte con l’affaticamento, ma è difficile da leggere su scansioni brevi.";
"hrv.metrics.vlfpower.high" = "Una VLF più alta è difficile da interpretare da sola.";
"hrv.metrics.vlfpower.reliability" = "Richiede una scansione lunga per avere senso.";
"hrv.metrics.totalpower.title" = "Potenza totale";
"hrv.metrics.totalpower.short" = "Potenza spettrale complessiva";
"hrv.metrics.totalpower.meaning" = "La somma della potenza su tutte le bande di frequenza, una misura complessiva della variabilità.";
"hrv.metrics.totalpower.low" = "Una potenza totale più bassa suggerisce una variabilità complessiva ridotta.";
"hrv.metrics.totalpower.high" = "Una potenza totale più alta suggerisce una maggiore variabilità complessiva.";
"hrv.metrics.totalpower.reliability" = "Richiede una scansione approfondita.";
"hrv.metrics.sd1.title" = "SD1";
"hrv.metrics.sd1.short" = "Larghezza di Poincaré a breve termine";
"hrv.metrics.sd1.meaning" = "La larghezza della nuvola di Poincaré, pari alla variabilità a breve termine e strettamente legata al RMSSD.";
"hrv.metrics.sd1.low" = "Un SD1 più basso suggerisce una ridotta variabilità parasimpatica a breve termine.";
"hrv.metrics.sd1.high" = "Un SD1 più alto suggerisce più variabilità a breve termine, spesso un buon recupero.";
"hrv.metrics.sd1.reliability" = "Affidabile su scansioni pulite.";
"hrv.metrics.sd2.title" = "SD2";
"hrv.metrics.sd2.short" = "Lunghezza di Poincaré a lungo termine";
"hrv.metrics.sd2.meaning" = "La lunghezza della nuvola di Poincaré, che riflette la variabilità a più lungo termine.";
"hrv.metrics.sd2.low" = "Un SD2 più basso suggerisce una variabilità a più lungo termine ridotta.";
"hrv.metrics.sd2.high" = "Un SD2 più alto suggerisce più variabilità a più lungo termine.";
"hrv.metrics.sd2.reliability" = "Più affidabile su scansioni più lunghe.";
"hrv.metrics.sd1sd2.title" = "SD1/SD2";
"hrv.metrics.sd1sd2.short" = "Equilibrio tra variabilità a breve e lungo termine";
"hrv.metrics.sd1sd2.meaning" = "Il rapporto tra SD1 e SD2, che descrive la forma della nuvola di Poincaré.";
"hrv.metrics.sd1sd2.low" = "Un rapporto più basso suggerisce che domina la variabilità a lungo termine.";
"hrv.metrics.sd1sd2.high" = "Un rapporto più alto suggerisce che domina la variabilità a breve termine.";
"hrv.metrics.sd1sd2.reliability" = "Leggilo insieme a SD1 e SD2.";
"hrv.metrics.sampleentropy.title" = "Entropia campionaria";
"hrv.metrics.sampleentropy.short" = "Complessità del segnale";
"hrv.metrics.sampleentropy.meaning" = "Una misura di quanto è irregolare e complesso il ritmo. I ritmi sani tendono a essere più complessi.";
"hrv.metrics.sampleentropy.low" = "Una complessità molto bassa può riflettere un ritmo più rigido.";
"hrv.metrics.sampleentropy.high" = "Una maggiore complessità riflette spesso un ritmo sano e adattabile.";
"hrv.metrics.sampleentropy.reliability" = "Richiede una scansione più lunga e pulita; non ancora calcolata in questa versione.";
"hrv.metrics.approximateentropy.title" = "Entropia approssimata";
"hrv.metrics.approximateentropy.short" = "Regolarità del segnale";
"hrv.metrics.approximateentropy.meaning" = "Una misura più vecchia della regolarità e complessità del ritmo, simile nello spirito all’entropia campionaria.";
"hrv.metrics.approximateentropy.low" = "Valori più bassi suggeriscono un ritmo più regolare e meno complesso.";
"hrv.metrics.approximateentropy.high" = "Valori più alti suggeriscono un ritmo più irregolare e complesso.";
"hrv.metrics.approximateentropy.reliability" = "Richiede una scansione più lunga; non ancora calcolata in questa versione.";
"hrv.metrics.dfaalpha1.title" = "DFA alpha1";
"hrv.metrics.dfaalpha1.short" = "Scaling frattale a breve termine";
"hrv.metrics.dfaalpha1.meaning" = "Analisi delle fluttuazioni senza tendenza su scale brevi, che descrive la struttura frattale del ritmo.";
"hrv.metrics.dfaalpha1.low" = "Valori ben al di sotto di 1 suggeriscono una dinamica a breve termine più casuale.";
"hrv.metrics.dfaalpha1.high" = "Valori vicini o superiori a 1 suggeriscono una dinamica a breve termine più correlata.";
"hrv.metrics.dfaalpha1.reliability" = "Richiede una scansione più lunga; non ancora calcolata in questa versione.";
"hrv.metrics.dfaalpha2.title" = "DFA alpha2";
"hrv.metrics.dfaalpha2.short" = "Scaling frattale a lungo termine";
"hrv.metrics.dfaalpha2.meaning" = "Analisi delle fluttuazioni senza tendenza su scale più lunghe.";
"hrv.metrics.dfaalpha2.low" = "Valori più bassi suggeriscono una dinamica a lungo termine meno correlata.";
"hrv.metrics.dfaalpha2.high" = "Valori più alti suggeriscono una dinamica a lungo termine più correlata.";
"hrv.metrics.dfaalpha2.reliability" = "Richiede una scansione lunga; non ancora calcolata in questa versione.";
