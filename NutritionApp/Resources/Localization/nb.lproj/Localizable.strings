"hrv.onboarding.camera_scan.body" = "Kameraet ser små fargeendringer i fingertuppen din. Disse endringene følger pulsbølgen din, og appen estimerer tiden mellom slagene.";
"hrv.onboarding.camera_scan.bullet_1" = "Dette er et kamerabasert HRV-estimat.";
"hrv.onboarding.camera_scan.bullet_2" = "Det er nyttig for trender når det måles nøye.";
"hrv.onboarding.camera_scan.bullet_3" = "Det er ikke EKG og ingen medisinsk diagnose.";
"hrv.onboarding.best_time.title" = "Når du bør måle";
"hrv.onboarding.best_time.body" = "For best trend, mål til samme tid hver morgen før koffein, mat, trening eller jobbstress.";
"hrv.onboarding.best_time.bullet_1" = "Mål etter at du har våknet.";
"hrv.onboarding.best_time.bullet_2" = "Mål før koffein eller mat.";
"hrv.onboarding.best_time.bullet_3" = "Bruk samme kroppsstilling hver dag.";
"hrv.onboarding.best_time.bullet_4" = "Prøv å måle i samme morgentidsrom.";
"hrv.onboarding.preparation.title" = "Før du begynner";
"hrv.onboarding.preparation.body" = "Ro er viktig. HRV er følsomt, så de reneste skanningene skjer når kroppen er rolig og fingeren holdes stille.";
"hrv.onboarding.preparation.bullet_1" = "Sitt eller legg deg ned.";
"hrv.onboarding.preparation.bullet_2" = "Hvil i ett til to minutter.";
"hrv.onboarding.preparation.bullet_3" = "Varm hendene hvis fingrene er kalde.";
"hrv.onboarding.preparation.bullet_4" = "Pust normalt og ikke snakk.";
"hrv.onboarding.finger_placement.title" = "Plasser fingeren forsiktig";
"hrv.onboarding.finger_placement.body" = "Dekk det bakre kameraet helt med fingertuppen. Bruk lett, jevnt trykk. Trykker du for hardt, endres blodstrømmen og skanningen blir mindre pålitelig.";
"hrv.onboarding.finger_placement.bullet_1" = "Dekk kameraet helt.";
"hrv.onboarding.finger_placement.bullet_2" = "Ikke trykk for hardt.";
"hrv.onboarding.finger_placement.bullet_3" = "Hold fingeren stille.";
"hrv.onboarding.during_scan.title" = "Under skanningen";
"hrv.onboarding.during_scan.body" = "Bare pust normalt. Ikke prøv å forbedre skåren. Målet er å fange den faktiske tilstanden din.";
"hrv.onboarding.during_scan.bullet_1" = "Vær stille.";
"hrv.onboarding.during_scan.bullet_2" = "Ikke snakk.";
"hrv.onboarding.during_scan.bullet_3" = "Fortsett å puste naturlig.";
"hrv.onboarding.scan_length.title" = "Velg skannedybde";
"hrv.onboarding.scan_length.body" = "Korte skanninger er nyttige for daglige trender. Lengre skanninger låser opp dypere HRV-mål.";
"hrv.onboarding.scan_length.bullet_1" = "Rask skanning: 60 til 120 sekunder for daglig beredskap.";
"hrv.onboarding.scan_length.bullet_2" = "Standardskanning: 5 minutter for dypere analyse.";
"hrv.onboarding.scan_length.bullet_3" = "Dyp skanning: 300 rene slag eller mer for avanserte HRV-mål.";
"hrv.onboarding.results.title" = "Slik leser du resultatet";
"hrv.onboarding.results.body" = "En skanning er et øyeblikksbilde. Den personlige trenden din er viktigere enn én enkelt verdi.";
"hrv.onboarding.results.bullet_1" = "Din personlige baselinje betyr mer enn et generelt område.";
"hrv.onboarding.results.bullet_2" = "Lav HRV kan gjenspeile stress, dårlig søvn, sykdom, dehydrering, alkohol eller hard trening.";
