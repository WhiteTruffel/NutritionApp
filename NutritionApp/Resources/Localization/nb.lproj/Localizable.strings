"hrv.onboarding.what_is_hrv.title" = "Hva er HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV betyr hjerteratevariabilitet. Det måler små endringer i tiden mellom hjerteslagene dine.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Hjertet ditt slår ikke som en perfekt metronom.";
