"hrv.onboarding.what_is_hrv.title" = "O que é a VFC?";
"hrv.onboarding.what_is_hrv.body" = "VFC significa variabilidade da frequência cardíaca. Mede pequenas variações de tempo entre os seus batimentos.";
"hrv.onboarding.what_is_hrv.bullet_1" = "O seu coração não bate como um metrónomo perfeito.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Um ritmo flexível pode refletir uma melhor adaptabilidade do sistema nervoso.";
"hrv.onboarding.what_is_hrv.bullet_3" = "A VFC pode ser afetada pelo sono, stress, doença, treino, álcool, cafeína, hidratação e pressão emocional.";
"hrv.onboarding.camera_scan.title" = "Como funciona a análise do telemóvel";
"hrv.onboarding.camera_scan.body" = "A câmara deteta pequenas alterações de cor na ponta do seu dedo. Estas alterações seguem a sua onda de pulso, e a aplicação estima o tempo entre batimentos.";
"hrv.onboarding.camera_scan.bullet_1" = "É uma estimativa da VFC baseada na câmara.";
"hrv.onboarding.camera_scan.bullet_2" = "É útil para tendências quando medida com cuidado.";
"hrv.onboarding.camera_scan.bullet_3" = "Não é um ECG nem um diagnóstico médico.";
"hrv.onboarding.best_time.title" = "Quando medir";
"hrv.onboarding.best_time.body" = "Para a melhor tendência, meça à mesma hora todas as manhãs antes da cafeína, da comida, do treino ou do stress do trabalho.";
"hrv.onboarding.best_time.bullet_1" = "Meça depois de acordar.";
"hrv.onboarding.best_time.bullet_2" = "Meça antes da cafeína ou da comida.";
"hrv.onboarding.best_time.bullet_3" = "Use a mesma posição do corpo todos os dias.";
"hrv.onboarding.best_time.bullet_4" = "Tente medir na mesma janela horária da manhã.";
"hrv.onboarding.preparation.title" = "Antes de começar";
"hrv.onboarding.preparation.body" = "A imobilidade importa. A VFC é sensível, por isso as análises mais limpas acontecem quando o seu corpo está calmo e o seu dedo se mantém firme.";
"hrv.onboarding.preparation.bullet_1" = "Sente-se ou deite-se.";
"hrv.onboarding.preparation.bullet_2" = "Descanse um a dois minutos.";
"hrv.onboarding.preparation.bullet_3" = "Aqueça as mãos se tiver os dedos frios.";
"hrv.onboarding.preparation.bullet_4" = "Respire normalmente e evite falar.";
"hrv.onboarding.finger_placement.title" = "Coloque o dedo com suavidade";
"hrv.onboarding.finger_placement.body" = "Cubra completamente a câmara traseira com a ponta do dedo. Aplique uma pressão suave e constante. Se pressionar com demasiada força, o fluxo sanguíneo muda e a análise torna-se menos fiável.";
"hrv.onboarding.finger_placement.bullet_1" = "Cubra a câmara completamente.";
"hrv.onboarding.finger_placement.bullet_2" = "Não pressione com demasiada força.";
"hrv.onboarding.finger_placement.bullet_3" = "Mantenha o dedo imóvel.";
"hrv.onboarding.during_scan.title" = "Durante a análise";
"hrv.onboarding.during_scan.body" = "Apenas respire normalmente. Não tente melhorar a pontuação. O objetivo é captar o seu estado real.";
"hrv.onboarding.during_scan.bullet_1" = "Fique imóvel.";
"hrv.onboarding.during_scan.bullet_2" = "Não fale.";
"hrv.onboarding.during_scan.bullet_3" = "Continue a respirar com naturalidade.";
"hrv.onboarding.scan_length.title" = "Escolha a profundidade da análise";
"hrv.onboarding.scan_length.body" = "As análises curtas são úteis para tendências diárias. As análises mais longas desbloqueiam métricas de VFC mais profundas.";
"hrv.onboarding.scan_length.bullet_1" = "Análise rápida: 60 a 120 segundos para a prontidão diária.";
"hrv.onboarding.scan_length.bullet_2" = "Análise padrão: 5 minutos para uma análise mais profunda.";
"hrv.onboarding.scan_length.bullet_3" = "Análise profunda: 300 batimentos limpos ou mais para métricas de VFC avançadas.";
"hrv.onboarding.results.title" = "Como ler o seu resultado";
"hrv.onboarding.results.body" = "Uma análise é um instantâneo. A sua tendência pessoal é mais importante do que um valor isolado.";
"hrv.onboarding.results.bullet_1" = "A sua referência pessoal importa mais do que um intervalo genérico.";
"hrv.onboarding.results.bullet_2" = "Uma VFC baixa pode refletir stress, mau sono, doença, desidratação, álcool ou treino intenso.";
"hrv.onboarding.results.bullet_3" = "Uma VFC alta pode significar boa recuperação, mas se se sentir exausto também pode refletir necessidade de recuperação.";
"hrv.onboarding.daily_guidance.title" = "As suas orientações diárias";
"hrv.onboarding.daily_guidance.body" = "A aplicação usa a sua tendência de VFC para tornar os lembretes diários mais pessoais.";
"hrv.onboarding.daily_guidance.bullet_1" = "Se mediu hoje, os lembretes podem incluir orientações baseadas na VFC.";
"hrv.onboarding.daily_guidance.bullet_2" = "Se não mediu, os lembretes irão incentivá-lo com suavidade a fazer uma análise.";
"hrv.onboarding.daily_guidance.bullet_3" = "Quanto mais consistente for ao medir, melhores serão as suas orientações.";
"hrv.onboarding.limitations.title" = "Limitações importantes";
"hrv.onboarding.limitations.body" = "A VFC não é um diagnóstico médico. Esta aplicação não deteta doenças cardíacas, arritmias nem emergências médicas.";
"hrv.onboarding.limitations.bullet_1" = "A VFC por câmara é uma estimativa, não um ECG.";
"hrv.onboarding.limitations.bullet_2" = "Movimento, dedos frios, pressão, medicação e arritmias podem afetar a precisão.";
"hrv.onboarding.limitations.bullet_3" = "Se sentir dor no peito, desmaios, falta de ar grave ou sintomas invulgares, procure ajuda médica.";
"hrv.onboarding.first_scan.title" = "Pronto para a sua primeira análise?";
"hrv.onboarding.first_scan.body" = "Faça agora a sua primeira análise em calma para que a aplicação possa começar a construir a sua referência pessoal de VFC.";
"hrv.onboarding.first_scan.primary_cta" = "Iniciar análise de VFC";
"hrv.onboarding.first_scan.secondary_cta" = "Lembrar-me mais tarde";
