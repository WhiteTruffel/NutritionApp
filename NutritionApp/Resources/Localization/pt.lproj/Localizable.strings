"hrv.reminders.with_measurement.normal.title" = "VFC equilibrada hoje";
"hrv.reminders.with_measurement.normal.body" = "A sua VFC parece equilibrada hoje. Mantenha o seu plano habitual e conserve o seu ritmo.";
"hrv.reminders.with_measurement.maintain.title" = "Ativação ligeira hoje";
"hrv.reminders.with_measurement.maintain.body" = "A sua VFC sugere uma ativação ligeira hoje. Pode ter desempenho, mas evite acumular demasiado stress.";
"hrv.reminders.with_measurement.recover.title" = "Hoje, primeiro a recuperação";
