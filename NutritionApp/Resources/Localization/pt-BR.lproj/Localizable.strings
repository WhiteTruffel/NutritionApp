"hrv.onboarding.what_is_hrv.title" = "O que é a VFC?";
"hrv.onboarding.what_is_hrv.body" = "VFC significa variabilidade da frequência cardíaca. Mede pequenas variações de tempo entre seus batimentos.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Seu coração não bate como um metrônomo perfeito.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Um ritmo flexível pode refletir uma melhor adaptabilidade do sistema nervoso.";
"hrv.onboarding.what_is_hrv.bullet_3" = "A VFC pode ser afetada pelo sono, estresse, doença, treino, álcool, cafeína, hidratação e pressão emocional.";
"hrv.onboarding.camera_scan.title" = "Como funciona a leitura pelo celular";
"hrv.onboarding.camera_scan.body" = "A câmera detecta pequenas mudanças de cor na ponta do seu dedo. Essas mudanças seguem sua onda de pulso, e o aplicativo estima o tempo entre batimentos.";
"hrv.onboarding.camera_scan.bullet_1" = "É uma estimativa da VFC baseada na câmera.";
"hrv.onboarding.camera_scan.bullet_2" = "É útil para tendências quando medida com cuidado.";
"hrv.onboarding.camera_scan.bullet_3" = "Não é um ECG nem um diagnóstico médico.";
"hrv.onboarding.best_time.title" = "Quando medir";
"hrv.onboarding.best_time.body" = "Para a melhor tendência, meça no mesmo horário toda manhã antes da cafeína, da comida, do treino ou do estresse do trabalho.";
"hrv.onboarding.best_time.bullet_1" = "Meça depois de acordar.";
"hrv.onboarding.best_time.bullet_2" = "Meça antes da cafeína ou da comida.";
"hrv.onboarding.best_time.bullet_3" = "Use a mesma posição do corpo todos os dias.";
"hrv.onboarding.best_time.bullet_4" = "Tente medir na mesma janela de horário pela manhã.";
"hrv.onboarding.preparation.title" = "Antes de começar";
"hrv.onboarding.preparation.body" = "A imobilidade importa. A VFC é sensível, então as leituras mais limpas acontecem quando seu corpo está calmo e seu dedo permanece firme.";
"hrv.onboarding.preparation.bullet_1" = "Sente-se ou deite-se.";
"hrv.onboarding.preparation.bullet_2" = "Descanse de um a dois minutos.";
"hrv.onboarding.preparation.bullet_3" = "Aqueça as mãos se seus dedos estiverem frios.";
"hrv.onboarding.preparation.bullet_4" = "Respire normalmente e evite falar.";
"hrv.onboarding.finger_placement.title" = "Posicione o dedo com suavidade";
"hrv.onboarding.finger_placement.body" = "Cubra completamente a câmera traseira com a ponta do dedo. Aplique uma pressão suave e constante. Se pressionar com muita força, o fluxo sanguíneo muda e a leitura fica menos confiável.";
"hrv.onboarding.finger_placement.bullet_1" = "Cubra a câmera completamente.";
"hrv.onboarding.finger_placement.bullet_2" = "Não pressione com muita força.";
"hrv.onboarding.finger_placement.bullet_3" = "Mantenha o dedo imóvel.";
"hrv.onboarding.during_scan.title" = "Durante a leitura";
"hrv.onboarding.during_scan.body" = "Apenas respire normalmente. Não tente melhorar a pontuação. O objetivo é captar seu estado real.";
"hrv.onboarding.during_scan.bullet_1" = "Fique imóvel.";
"hrv.onboarding.during_scan.bullet_2" = "Não fale.";
"hrv.onboarding.during_scan.bullet_3" = "Continue respirando com naturalidade.";
"hrv.onboarding.scan_length.title" = "Escolha a profundidade da leitura";
"hrv.onboarding.scan_length.body" = "As leituras curtas são úteis para tendências diárias. As leituras mais longas desbloqueiam métricas de VFC mais profundas.";
"hrv.onboarding.scan_length.bullet_1" = "Leitura rápida: 60 a 120 segundos para a prontidão diária.";
"hrv.onboarding.scan_length.bullet_2" = "Leitura padrão: 5 minutos para uma análise mais profunda.";
"hrv.onboarding.scan_length.bullet_3" = "Leitura profunda: 300 batimentos limpos ou mais para métricas de VFC avançadas.";
"hrv.onboarding.results.title" = "Como ler seu resultado";
"hrv.onboarding.results.body" = "Uma leitura é um instantâneo. Sua tendência pessoal é mais importante do que um valor isolado.";
"hrv.onboarding.results.bullet_1" = "Sua referência pessoal importa mais do que um intervalo genérico.";
"hrv.onboarding.results.bullet_2" = "Uma VFC baixa pode refletir estresse, sono ruim, doença, desidratação, álcool ou treino intenso.";
"hrv.onboarding.results.bullet_3" = "Uma VFC alta pode significar boa recuperação, mas se você se sentir exausto também pode refletir necessidade de recuperação.";
"hrv.onboarding.daily_guidance.title" = "Suas orientações diárias";
"hrv.onboarding.daily_guidance.body" = "O aplicativo usa sua tendência de VFC para deixar os lembretes diários mais pessoais.";
"hrv.onboarding.daily_guidance.bullet_1" = "Se você mediu hoje, os lembretes podem incluir orientações baseadas na VFC.";
"hrv.onboarding.daily_guidance.bullet_2" = "Se você não mediu, os lembretes vão incentivá-lo com suavidade a fazer uma leitura.";
"hrv.onboarding.daily_guidance.bullet_3" = "Quanto mais constante você for ao medir, melhores ficam suas orientações.";
"hrv.onboarding.limitations.title" = "Limitações importantes";
"hrv.onboarding.limitations.body" = "A VFC não é um diagnóstico médico. Este aplicativo não detecta doenças cardíacas, arritmias nem emergências médicas.";
"hrv.onboarding.limitations.bullet_1" = "A VFC por câmera é uma estimativa, não um ECG.";
"hrv.onboarding.limitations.bullet_2" = "Movimento, dedos frios, pressão, medicação e arritmias podem afetar a precisão.";
"hrv.onboarding.limitations.bullet_3" = "Se você sentir dor no peito, desmaios, falta de ar grave ou sintomas incomuns, procure ajuda médica.";
"hrv.onboarding.first_scan.title" = "Pronto para sua primeira leitura?";
"hrv.onboarding.first_scan.body" = "Faça agora sua primeira leitura com calma para que o aplicativo possa começar a construir sua referência pessoal de VFC.";
"hrv.onboarding.first_scan.primary_cta" = "Iniciar leitura de VFC";
"hrv.onboarding.first_scan.secondary_cta" = "Lembrar mais tarde";
