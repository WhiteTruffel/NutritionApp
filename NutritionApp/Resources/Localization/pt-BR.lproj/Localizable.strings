"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Variabilidade de curto prazo";
"hrv.metrics.rmssd.meaning" = "O RMSSD reflete as mudanças batimento a batimento, impulsionadas principalmente pelo ramo parassimpático (de recuperação) do seu sistema nervoso.";
"hrv.metrics.rmssd.low" = "Um RMSSD mais baixo do que o habitual pode refletir estresse, sono ruim, doença ou treino intenso.";
"hrv.metrics.rmssd.high" = "Um RMSSD mais alto reflete muitas vezes uma boa recuperação, embora valores incomumente altos com fadiga possam indicar necessidade de recuperação.";
"hrv.metrics.rmssd.reliability" = "Confiável mesmo em leituras curtas e com calma.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Variabilidade geral";
"hrv.metrics.sdnn.meaning" = "O SDNN capta a dispersão geral da duração dos seus intervalos, refletindo ambos os ramos do seu sistema nervoso.";
"hrv.metrics.sdnn.low" = "Um SDNN mais baixo pode refletir uma adaptabilidade geral reduzida.";
"hrv.metrics.sdnn.high" = "Um SDNN mais alto reflete em geral uma maior variabilidade geral.";
"hrv.metrics.sdnn.reliability" = "Mais confiável em leituras mais longas.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Proporção de grandes variações entre batimentos";
"hrv.metrics.pnn50.meaning" = "O pNN50 é a porcentagem de batimentos adjacentes que diferem em mais de 50 ms, outro marcador parassimpático.";
"hrv.metrics.pnn50.low" = "Um pNN50 baixo pode acompanhar estresse ou fadiga.";
"hrv.metrics.pnn50.high" = "Um pNN50 mais alto acompanha em geral estados relaxados e bem recuperados.";
"hrv.metrics.pnn50.reliability" = "Utilizável em leituras curtas, mas mais ruidoso do que o RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Agrupamento de batimentos";
"hrv.metrics.amo50.meaning" = "O AMo50 descreve quão próximos seus intervalos se agrupam em torno do valor mais frequente; um agrupamento mais estreito sugere uma maior ativação simpática.";
"hrv.metrics.amo50.low" = "Um AMo50 mais baixo sugere um ritmo mais relaxado e variável.";
"hrv.metrics.amo50.high" = "Um AMo50 mais alto sugere um ritmo mais rígido e ativado.";
"hrv.metrics.amo50.reliability" = "Melhor em leituras padrão ou mais longas.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Equilíbrio de frequências (apenas contexto)";
"hrv.metrics.lfhf.meaning" = "O LF/HF compara a potência das baixas e altas frequências. É fácil de interpretar errado, então este aplicativo o trata apenas como contexto de apoio, nunca como um simples medidor de estresse.";
"hrv.metrics.lfhf.low" = "Interprete com cautela; muitos fatores movem essa razão.";
"hrv.metrics.lfhf.high" = "Interprete com cautela; muitos fatores movem essa razão.";
"hrv.metrics.lfhf.reliability" = "Requer uma leitura profunda e é sensível à respiração.";
"hrv.metrics.hr.title" = "Frequência cardíaca";
"hrv.metrics.hr.short" = "Batimentos por minuto";
"hrv.metrics.hr.meaning" = "Frequência cardíaca média durante a leitura, derivada do tempo médio entre batimentos.";
"hrv.metrics.hr.low" = "Uma frequência cardíaca em repouso mais baixa costuma acompanhar boa forma física e recuperação.";
"hrv.metrics.hr.high" = "Uma frequência cardíaca mais alta do que o habitual pode refletir estresse, estimulantes, doença ou recuperação ruim.";
"hrv.metrics.hr.reliability" = "Confiável em qualquer leitura limpa.";
"hrv.metrics.meannn.title" = "NN médio";
"hrv.metrics.meannn.short" = "Intervalo médio entre batimentos";
"hrv.metrics.meannn.meaning" = "O tempo médio entre batimentos em milissegundos. É o inverso da frequência cardíaca.";
"hrv.metrics.meannn.low" = "Intervalos mais curtos significam uma frequência cardíaca mais rápida.";
"hrv.metrics.meannn.high" = "Intervalos mais longos significam uma frequência cardíaca mais lenta.";
"hrv.metrics.meannn.reliability" = "Confiável em qualquer leitura limpa.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "RMSSD em escala logarítmica";
"hrv.metrics.lnrmssd.meaning" = "O logaritmo natural do RMSSD. Comprime o intervalo para que as tendências de um dia para o outro fiquem mais fáceis de comparar.";
"hrv.metrics.lnrmssd.low" = "Valores mais baixos acompanham um RMSSD mais baixo, muitas vezes estresse ou fadiga.";
"hrv.metrics.lnrmssd.high" = "Valores mais altos acompanham um RMSSD mais alto, muitas vezes boa recuperação.";
"hrv.metrics.lnrmssd.reliability" = "Preferido para a análise de tendências por ser mais estável.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Contagem de grandes variações entre batimentos";
"hrv.metrics.nn50.meaning" = "O número de batimentos adjacentes que diferem em mais de 50 ms.";
"hrv.metrics.nn50.low" = "Uma contagem baixa pode acompanhar estresse ou fadiga.";
"hrv.metrics.nn50.high" = "Uma contagem mais alta acompanha em geral um estado relaxado e bem recuperado.";
"hrv.metrics.nn50.reliability" = "Utilizável em leituras curtas, mas mais ruidoso do que o RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Dispersão das variações entre batimentos";
"hrv.metrics.sdsd.meaning" = "O desvio padrão das diferenças entre batimentos adjacentes, uma medida de variabilidade de curto prazo.";
"hrv.metrics.sdsd.low" = "Um SDSD mais baixo sugere uma variabilidade de curto prazo reduzida.";
"hrv.metrics.sdsd.high" = "Um SDSD mais alto sugere mais variabilidade de curto prazo, muitas vezes boa recuperação.";
"hrv.metrics.sdsd.reliability" = "Utilizável em leituras curtas e com calma.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Variabilidade geral relativa";
"hrv.metrics.cvnn.meaning" = "O SDNN dividido pelo intervalo médio, de modo que a variabilidade é expressa em relação à frequência cardíaca.";
"hrv.metrics.cvnn.low" = "Um CVNN mais baixo sugere uma variabilidade relativa reduzida.";
"hrv.metrics.cvnn.high" = "Um CVNN mais alto sugere uma maior variabilidade relativa.";
"hrv.metrics.cvnn.reliability" = "Mais confiável em leituras mais longas.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Variabilidade de curto prazo relativa";
"hrv.metrics.cvsd.meaning" = "O RMSSD dividido pelo intervalo médio, a variabilidade de curto prazo em relação à frequência cardíaca.";
"hrv.metrics.cvsd.low" = "Um CVSD mais baixo sugere uma variabilidade de curto prazo relativa reduzida.";
"hrv.metrics.cvsd.high" = "Um CVSD mais alto sugere mais variabilidade de curto prazo relativa.";
"hrv.metrics.cvsd.reliability" = "Utilizável em leituras curtas.";
"hrv.metrics.modenn.title" = "NN modal";
"hrv.metrics.modenn.short" = "Intervalo entre batimentos mais frequente";
"hrv.metrics.modenn.meaning" = "A duração de intervalo mais frequente, o centro da barra mais alta do histograma.";
"hrv.metrics.modenn.low" = "Uma moda mais curta significa uma frequência cardíaca típica mais rápida.";
"hrv.metrics.modenn.high" = "Uma moda mais longa significa uma frequência cardíaca típica mais lenta.";
"hrv.metrics.modenn.reliability" = "Melhor em leituras padrão ou mais longas.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Amplitude dos intervalos";
"hrv.metrics.mxdmn.meaning" = "A diferença entre o intervalo mais longo e o mais curto da leitura.";
"hrv.metrics.mxdmn.low" = "Uma amplitude pequena sugere um ritmo estável.";
"hrv.metrics.mxdmn.high" = "Uma amplitude grande pode refletir uma alta variabilidade ou artefatos.";
"hrv.metrics.mxdmn.reliability" = "Sensível a valores atípicos isolados, interprete com cuidado.";
"hrv.metrics.triangularindex.title" = "Índice triangular";
"hrv.metrics.triangularindex.short" = "Variabilidade geral geométrica";
"hrv.metrics.triangularindex.meaning" = "O número total de intervalos dividido pela altura do pico do histograma, uma medida geométrica da variabilidade geral.";
"hrv.metrics.triangularindex.low" = "Valores mais baixos sugerem uma variabilidade geral reduzida.";
"hrv.metrics.triangularindex.high" = "Valores mais altos sugerem uma maior variabilidade geral.";
"hrv.metrics.triangularindex.reliability" = "Requer pelo menos alguns minutos de batimentos.";
"hrv.metrics.tinn.title" = "TINN";
"hrv.metrics.tinn.short" = "Largura de base do histograma";
"hrv.metrics.tinn.meaning" = "A largura de base do histograma de intervalos, outra medida geométrica da variabilidade geral.";
"hrv.metrics.tinn.low" = "Valores mais baixos sugerem uma variabilidade geral reduzida.";
