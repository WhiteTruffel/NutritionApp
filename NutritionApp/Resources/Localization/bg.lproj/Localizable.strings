"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Краткосрочна вариабилност";
"hrv.metrics.rmssd.meaning" = "RMSSD отразява промените между отделните удари, движени основно от парасимпатиковия (възстановителен) клон на нервната ви система.";
