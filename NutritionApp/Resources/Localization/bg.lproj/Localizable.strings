"hrv.metrics.sdnn.low" = "По-ниско SDNN може да отразява намалена обща приспособимост.";
"hrv.metrics.sdnn.high" = "По-високо SDNN обикновено отразява по-голяма обща вариабилност.";
"hrv.metrics.sdnn.reliability" = "По-надеждно при по-дълги сканирания.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Дял на големите промени в ударите";
"hrv.metrics.pnn50.meaning" = "pNN50 е процентът на съседните удари, които се различават с повече от 50 ms, друг парасимпатиков маркер.";
"hrv.metrics.pnn50.low" = "Ниско pNN50 може да съпътства стрес или умора.";
"hrv.metrics.pnn50.high" = "По-високо pNN50 обикновено съпътства отпуснати, добре възстановени състояния.";
"hrv.metrics.pnn50.reliability" = "Използваемо при кратки сканирания, но по-шумно от RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
