"hrv.metrics.rmssd.high" = "По-високо RMSSD често отразява добро възстановяване, макар необичайно високи стойности при умора да означават нужда от възстановяване.";
"hrv.metrics.rmssd.reliability" = "Надеждно дори при кратки, спокойни сканирания.";
"hrv.metrics.sdnn.title" = "SDNN";
