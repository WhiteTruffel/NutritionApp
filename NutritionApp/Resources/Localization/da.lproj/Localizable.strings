"hrv.onboarding.what_is_hrv.title" = "Hvad er HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV betyder hjerterytmevariabilitet. Det måler små ændringer i tiden mellem dine hjerteslag.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Dit hjerte slår ikke som en perfekt metronom.";
"hrv.onboarding.what_is_hrv.bullet_2" = "En fleksibel rytme kan afspejle bedre tilpasningsevne i nervesystemet.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV kan påvirkes af søvn, stress, sygdom, træning, alkohol, koffein, væskebalance og følelsesmæssigt pres.";
"hrv.onboarding.camera_scan.title" = "Sådan virker scanningen med telefonen";
"hrv.onboarding.camera_scan.body" = "Kameraet ser små farveændringer i din fingerspids. Disse ændringer følger din pulsbølge, og appen estimerer tiden mellem slagene.";
"hrv.onboarding.camera_scan.bullet_1" = "Dette er et kamerabaseret HRV-estimat.";
"hrv.onboarding.camera_scan.bullet_2" = "Det er nyttigt til tendenser, når det måles omhyggeligt.";
"hrv.onboarding.camera_scan.bullet_3" = "Det er ikke EKG og ikke en medicinsk diagnose.";
"hrv.onboarding.best_time.title" = "Hvornår du skal måle";
"hrv.onboarding.best_time.body" = "For den bedste tendens skal du måle på samme tid hver morgen før koffein, mad, træning eller arbejdsstress.";
"hrv.onboarding.best_time.bullet_1" = "Mål efter opvågning.";
"hrv.onboarding.best_time.bullet_2" = "Mål før koffein eller mad.";
"hrv.onboarding.best_time.bullet_3" = "Brug samme kropsstilling hver dag.";
"hrv.onboarding.best_time.bullet_4" = "Forsøg at måle i samme morgentidsrum.";
"hrv.onboarding.preparation.title" = "Før du begynder";
"hrv.onboarding.preparation.body" = "Ro betyder noget. HRV er følsomt, så de reneste scanninger sker, når kroppen er rolig og fingeren holdes stille.";
"hrv.onboarding.preparation.bullet_1" = "Sid eller læg dig ned.";
"hrv.onboarding.preparation.bullet_2" = "Hvil i et til to minutter.";
"hrv.onboarding.preparation.bullet_3" = "Varm hænderne, hvis fingrene er kolde.";
"hrv.onboarding.preparation.bullet_4" = "Træk vejret normalt og undlad at tale.";
"hrv.onboarding.finger_placement.title" = "Placer fingeren forsigtigt";
"hrv.onboarding.finger_placement.body" = "Dæk det bagerste kamera helt med din fingerspids. Brug let, jævnt tryk. Trykker du for hårdt, ændres blodgennemstrømningen, og scanningen bliver mindre pålidelig.";
"hrv.onboarding.finger_placement.bullet_1" = "Dæk kameraet helt.";
"hrv.onboarding.finger_placement.bullet_2" = "Tryk ikke for hårdt.";
"hrv.onboarding.finger_placement.bullet_3" = "Hold fingeren stille.";
"hrv.onboarding.during_scan.title" = "Under scanningen";
"hrv.onboarding.during_scan.body" = "Træk bare vejret normalt. Forsøg ikke at forbedre scoren. Målet er at fange din reelle tilstand.";
"hrv.onboarding.during_scan.bullet_1" = "Hold dig stille.";
"hrv.onboarding.during_scan.bullet_2" = "Tal ikke.";
"hrv.onboarding.during_scan.bullet_3" = "Bliv ved med at trække vejret naturligt.";
"hrv.onboarding.scan_length.title" = "Vælg scanningsdybde";
"hrv.onboarding.scan_length.body" = "Korte scanninger er nyttige til daglige tendenser. Længere scanninger låser dybere HRV-mål op.";
"hrv.onboarding.scan_length.bullet_1" = "Hurtig scanning: 60 til 120 sekunder til daglig parathed.";
"hrv.onboarding.scan_length.bullet_2" = "Standardscanning: 5 minutter til dybere analyse.";
"hrv.onboarding.scan_length.bullet_3" = "Dyb scanning: 300 rene slag eller mere til avancerede HRV-mål.";
"hrv.onboarding.results.title" = "Sådan læser du dit resultat";
"hrv.onboarding.results.body" = "En scanning er et øjebliksbillede. Din personlige tendens er vigtigere end én enkelt værdi.";
"hrv.onboarding.results.bullet_1" = "Din personlige baseline betyder mere end et generelt interval.";
"hrv.onboarding.results.bullet_2" = "Lav HRV kan afspejle stress, dårlig søvn, sygdom, dehydrering, alkohol eller hård træning.";
"hrv.onboarding.results.bullet_3" = "Høj HRV kan betyde god restitution, men hvis du føler dig udmattet, kan den også afspejle behov for restitution.";
"hrv.onboarding.daily_guidance.title" = "Din daglige vejledning";
"hrv.onboarding.daily_guidance.body" = "Appen bruger din HRV-tendens til at gøre daglige påmindelser mere personlige.";
"hrv.onboarding.daily_guidance.bullet_1" = "Hvis du målte i dag, kan påmindelser indeholde HRV-baseret vejledning.";
"hrv.onboarding.daily_guidance.bullet_2" = "Hvis du ikke har målt, minder appen dig blidt om at lave en scanning.";
"hrv.onboarding.daily_guidance.bullet_3" = "Jo mere konsekvent du måler, desto bedre bliver din vejledning.";
"hrv.onboarding.limitations.title" = "Vigtige begrænsninger";
"hrv.onboarding.limitations.body" = "HRV er ikke en medicinsk diagnose. Denne app registrerer ikke hjertesygdom, arytmier eller akutte nødsituationer.";
"hrv.onboarding.limitations.bullet_1" = "Kamera-HRV er et estimat, ikke EKG.";
