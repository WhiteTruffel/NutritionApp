"hrv.onboarding.what_is_hrv.title" = "¿Qué es la VFC?";
"hrv.onboarding.what_is_hrv.body" = "VFC significa variabilidad de la frecuencia cardíaca. Mide pequeñas variaciones de tiempo entre tus latidos.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Tu corazón no late como un metrónomo perfecto.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Un ritmo flexible puede reflejar una mejor adaptabilidad del sistema nervioso.";
"hrv.onboarding.what_is_hrv.bullet_3" = "La VFC puede verse afectada por el sueño, el estrés, la enfermedad, el entrenamiento, el alcohol, la cafeína, la hidratación y la presión emocional.";
"hrv.onboarding.camera_scan.title" = "Cómo funciona el escaneo del teléfono";
"hrv.onboarding.camera_scan.body" = "La cámara detecta pequeños cambios de color en la yema de tu dedo. Estos cambios siguen tu onda de pulso, y la aplicación estima el tiempo entre latidos.";
"hrv.onboarding.camera_scan.bullet_1" = "Es una estimación de la VFC basada en la cámara.";
"hrv.onboarding.camera_scan.bullet_2" = "Es útil para las tendencias cuando se mide con cuidado.";
"hrv.onboarding.camera_scan.bullet_3" = "No es un ECG ni un diagnóstico médico.";
"hrv.onboarding.best_time.title" = "Cuándo medir";
"hrv.onboarding.best_time.body" = "Para la mejor tendencia, mide a la misma hora cada mañana antes de la cafeína, la comida, el entrenamiento o el estrés del trabajo.";
"hrv.onboarding.best_time.bullet_1" = "Mide después de despertar.";
"hrv.onboarding.best_time.bullet_2" = "Mide antes de la cafeína o la comida.";
"hrv.onboarding.best_time.bullet_3" = "Usa la misma posición corporal cada día.";
"hrv.onboarding.best_time.bullet_4" = "Intenta medir en la misma franja horaria por la mañana.";
"hrv.onboarding.preparation.title" = "Antes de empezar";
"hrv.onboarding.preparation.body" = "La quietud importa. La VFC es sensible, por lo que los escaneos más limpios se producen cuando tu cuerpo está tranquilo y tu dedo se mantiene firme.";
"hrv.onboarding.preparation.bullet_1" = "Siéntate o recuéstate.";
"hrv.onboarding.preparation.bullet_2" = "Descansa de uno a dos minutos.";
"hrv.onboarding.preparation.bullet_3" = "Calienta tus manos si tienes los dedos fríos.";
"hrv.onboarding.preparation.bullet_4" = "Respira con normalidad y evita hablar.";
"hrv.onboarding.finger_placement.title" = "Coloca tu dedo con suavidad";
"hrv.onboarding.finger_placement.body" = "Cubre por completo la cámara trasera con la yema de tu dedo. Aplica una presión suave y constante. Si presionas demasiado fuerte, el flujo sanguíneo cambia y el escaneo se vuelve menos fiable.";
"hrv.onboarding.finger_placement.bullet_1" = "Cubre la cámara por completo.";
"hrv.onboarding.finger_placement.bullet_2" = "No presiones demasiado fuerte.";
"hrv.onboarding.finger_placement.bullet_3" = "Mantén tu dedo quieto.";
"hrv.onboarding.during_scan.title" = "Durante el escaneo";
"hrv.onboarding.during_scan.body" = "Solo respira con normalidad. No intentes mejorar la puntuación. El objetivo es capturar tu estado real.";
"hrv.onboarding.during_scan.bullet_1" = "Quédate quieto.";
"hrv.onboarding.during_scan.bullet_2" = "No hables.";
"hrv.onboarding.during_scan.bullet_3" = "Sigue respirando con naturalidad.";
"hrv.onboarding.scan_length.title" = "Elige la profundidad del escaneo";
"hrv.onboarding.scan_length.body" = "Los escaneos cortos son útiles para las tendencias diarias. Los escaneos más largos desbloquean métricas de VFC más profundas.";
"hrv.onboarding.scan_length.bullet_1" = "Escaneo rápido: 60 a 120 segundos para la disposición diaria.";
"hrv.onboarding.scan_length.bullet_2" = "Escaneo estándar: 5 minutos para un análisis más profundo.";
"hrv.onboarding.scan_length.bullet_3" = "Escaneo profundo: 300 latidos limpios o más para métricas de VFC avanzadas.";
"hrv.onboarding.results.title" = "Cómo leer tu resultado";
"hrv.onboarding.results.body" = "Un escaneo es una instantánea. Tu tendencia personal es más importante que un valor aislado.";
"hrv.onboarding.results.bullet_1" = "Tu referencia personal importa más que un rango genérico.";
"hrv.onboarding.results.bullet_2" = "Una VFC baja puede reflejar estrés, mal sueño, enfermedad, deshidratación, alcohol o entrenamiento intenso.";
"hrv.onboarding.results.bullet_3" = "Una VFC alta puede significar buena recuperación, pero si te sientes agotado también puede reflejar necesidad de recuperación.";
"hrv.onboarding.daily_guidance.title" = "Tus consejos diarios";
"hrv.onboarding.daily_guidance.body" = "La aplicación usa tu tendencia de VFC para hacer más personales los recordatorios diarios.";
"hrv.onboarding.daily_guidance.bullet_1" = "Si mediste hoy, los recordatorios pueden incluir consejos basados en la VFC.";
"hrv.onboarding.daily_guidance.bullet_2" = "Si no has medido, los recordatorios te animarán con suavidad a hacer un escaneo.";
"hrv.onboarding.daily_guidance.bullet_3" = "Cuanto más constante seas al medir, mejores serán tus consejos.";
"hrv.onboarding.limitations.title" = "Limitaciones importantes";
"hrv.onboarding.limitations.body" = "La VFC no es un diagnóstico médico. Esta aplicación no detecta enfermedades cardíacas, arritmias ni emergencias médicas.";
"hrv.onboarding.limitations.bullet_1" = "La VFC por cámara es una estimación, no un ECG.";
"hrv.onboarding.limitations.bullet_2" = "El movimiento, los dedos fríos, la presión, la medicación y las arritmias pueden afectar la precisión.";
"hrv.onboarding.limitations.bullet_3" = "Si sientes dolor en el pecho, desmayos, falta de aire grave o síntomas inusuales, busca ayuda médica.";
"hrv.onboarding.first_scan.title" = "¿Listo para tu primer escaneo?";
"hrv.onboarding.first_scan.body" = "Haz tu primer escaneo en calma ahora para que la aplicación pueda empezar a crear tu referencia personal de VFC.";
"hrv.onboarding.first_scan.primary_cta" = "Iniciar escaneo de VFC";
"hrv.onboarding.first_scan.secondary_cta" = "Recordármelo más tarde";
