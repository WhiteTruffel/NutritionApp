"hrv.reminders.with_measurement.push.body" = "Tu señal de recuperación parece fuerte hoy. Buen día para un trabajo concentrado o un entrenamiento más fuerte si te sientes bien.";
"hrv.reminders.with_measurement.normal.title" = "VFC equilibrada hoy";
"hrv.reminders.with_measurement.normal.body" = "Tu VFC parece equilibrada hoy. Mantén tu plan habitual y conserva tu ritmo.";
"hrv.reminders.with_measurement.maintain.title" = "Activación leve hoy";
"hrv.reminders.with_measurement.maintain.body" = "Tu VFC sugiere una activación leve hoy. Puedes rendir, pero evita acumular demasiado estrés.";
"hrv.reminders.with_measurement.recover.title" = "Hoy, primero la recuperación";
"hrv.reminders.with_measurement.recover.body" = "Tus marcadores de recuperación están reducidos hoy. Elige un movimiento más suave, hidratación y acostarte más temprano si es posible.";
"hrv.reminders.with_measurement.uncertain.title" = "VFC poco clara hoy";
