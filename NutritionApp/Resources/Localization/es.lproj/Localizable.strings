"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Variabilidad a corto plazo";
"hrv.metrics.rmssd.meaning" = "El RMSSD refleja los cambios latido a latido, impulsados principalmente por la rama parasimpática (de recuperación) de tu sistema nervioso.";
"hrv.metrics.rmssd.low" = "Un RMSSD más bajo de lo habitual puede reflejar estrés, mal sueño, enfermedad o entrenamiento intenso.";
"hrv.metrics.rmssd.high" = "Un RMSSD más alto suele reflejar una buena recuperación, aunque valores inusualmente altos con fatiga pueden indicar necesidad de recuperación.";
"hrv.metrics.rmssd.reliability" = "Fiable incluso en escaneos cortos y en calma.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Variabilidad general";
"hrv.metrics.sdnn.meaning" = "El SDNN capta la dispersión general de la duración de tus intervalos, reflejando ambas ramas de tu sistema nervioso.";
"hrv.metrics.sdnn.low" = "Un SDNN más bajo puede reflejar una adaptabilidad general reducida.";
"hrv.metrics.sdnn.high" = "Un SDNN más alto refleja por lo general una mayor variabilidad general.";
"hrv.metrics.sdnn.reliability" = "Más fiable en escaneos más largos.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Proporción de grandes cambios entre latidos";
"hrv.metrics.pnn50.meaning" = "El pNN50 es el porcentaje de latidos adyacentes que difieren en más de 50 ms, otro marcador parasimpático.";
"hrv.metrics.pnn50.low" = "Un pNN50 bajo puede acompañar al estrés o la fatiga.";
"hrv.metrics.pnn50.high" = "Un pNN50 más alto suele acompañar a estados relajados y bien recuperados.";
"hrv.metrics.pnn50.reliability" = "Utilizable en escaneos cortos, pero más ruidoso que el RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Agrupamiento de latidos";
"hrv.metrics.amo50.meaning" = "El AMo50 describe cómo de juntos se agrupan tus intervalos en torno al valor más frecuente; un agrupamiento más estrecho sugiere una mayor activación simpática.";
"hrv.metrics.amo50.low" = "Un AMo50 más bajo sugiere un ritmo más relajado y variable.";
"hrv.metrics.amo50.high" = "Un AMo50 más alto sugiere un ritmo más rígido y activado.";
"hrv.metrics.amo50.reliability" = "Mejor en escaneos estándar o más largos.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Equilibrio de frecuencias (solo contexto)";
"hrv.metrics.lfhf.meaning" = "El LF/HF compara la potencia de las frecuencias bajas y altas. Es fácil de malinterpretar, por lo que esta aplicación lo trata solo como contexto de apoyo, nunca como un simple medidor de estrés.";
"hrv.metrics.lfhf.low" = "Interpreta con cautela; muchos factores mueven esta proporción.";
"hrv.metrics.lfhf.high" = "Interpreta con cautela; muchos factores mueven esta proporción.";
"hrv.metrics.lfhf.reliability" = "Requiere un escaneo profundo y es sensible a la respiración.";
"hrv.metrics.hr.title" = "Frecuencia cardíaca";
"hrv.metrics.hr.short" = "Latidos por minuto";
"hrv.metrics.hr.meaning" = "Frecuencia cardíaca media durante el escaneo, derivada del tiempo medio entre latidos.";
"hrv.metrics.hr.low" = "Una frecuencia cardíaca en reposo más baja suele ir acompañada de buena forma física y recuperación.";
"hrv.metrics.hr.high" = "Una frecuencia cardíaca más alta de lo habitual puede reflejar estrés, estimulantes, enfermedad o mala recuperación.";
"hrv.metrics.hr.reliability" = "Fiable en cualquier escaneo limpio.";
"hrv.metrics.meannn.title" = "NN medio";
"hrv.metrics.meannn.short" = "Intervalo medio entre latidos";
"hrv.metrics.meannn.meaning" = "El tiempo medio entre latidos en milisegundos. Es el inverso de la frecuencia cardíaca.";
"hrv.metrics.meannn.low" = "Intervalos más cortos significan una frecuencia cardíaca más rápida.";
"hrv.metrics.meannn.high" = "Intervalos más largos significan una frecuencia cardíaca más lenta.";
"hrv.metrics.meannn.reliability" = "Fiable en cualquier escaneo limpio.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "RMSSD en escala logarítmica";
"hrv.metrics.lnrmssd.meaning" = "El logaritmo natural del RMSSD. Comprime el rango para que las tendencias de un día a otro sean más fáciles de comparar.";
"hrv.metrics.lnrmssd.low" = "Valores más bajos siguen a un RMSSD más bajo, a menudo estrés o fatiga.";
"hrv.metrics.lnrmssd.high" = "Valores más altos siguen a un RMSSD más alto, a menudo buena recuperación.";
"hrv.metrics.lnrmssd.reliability" = "Preferido para el análisis de tendencias porque es más estable.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Recuento de grandes cambios entre latidos";
"hrv.metrics.nn50.meaning" = "El número de latidos adyacentes que difieren en más de 50 ms.";
"hrv.metrics.nn50.low" = "Un recuento bajo puede acompañar al estrés o la fatiga.";
"hrv.metrics.nn50.high" = "Un recuento más alto suele acompañar a un estado relajado y bien recuperado.";
"hrv.metrics.nn50.reliability" = "Utilizable en escaneos cortos, pero más ruidoso que el RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Dispersión de los cambios entre latidos";
"hrv.metrics.sdsd.meaning" = "La desviación estándar de las diferencias entre latidos adyacentes, una medida de variabilidad a corto plazo.";
"hrv.metrics.sdsd.low" = "Un SDSD más bajo sugiere una variabilidad a corto plazo reducida.";
"hrv.metrics.sdsd.high" = "Un SDSD más alto sugiere más variabilidad a corto plazo, a menudo buena recuperación.";
"hrv.metrics.sdsd.reliability" = "Utilizable en escaneos cortos y en calma.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Variabilidad general relativa";
"hrv.metrics.cvnn.meaning" = "El SDNN dividido por el intervalo medio, de modo que la variabilidad se expresa en relación con la frecuencia cardíaca.";
"hrv.metrics.cvnn.low" = "Un CVNN más bajo sugiere una variabilidad relativa reducida.";
"hrv.metrics.cvnn.high" = "Un CVNN más alto sugiere una mayor variabilidad relativa.";
"hrv.metrics.cvnn.reliability" = "Más fiable en escaneos más largos.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Variabilidad a corto plazo relativa";
"hrv.metrics.cvsd.meaning" = "El RMSSD dividido por el intervalo medio, la variabilidad a corto plazo en relación con la frecuencia cardíaca.";
"hrv.metrics.cvsd.low" = "Un CVSD más bajo sugiere una variabilidad a corto plazo relativa reducida.";
"hrv.metrics.cvsd.high" = "Un CVSD más alto sugiere más variabilidad a corto plazo relativa.";
"hrv.metrics.cvsd.reliability" = "Utilizable en escaneos cortos.";
"hrv.metrics.modenn.title" = "NN modal";
"hrv.metrics.modenn.short" = "Intervalo entre latidos más frecuente";
"hrv.metrics.modenn.meaning" = "La duración de intervalo más frecuente, el centro de la barra más alta del histograma.";
"hrv.metrics.modenn.low" = "Un modo más corto significa una frecuencia cardíaca típica más rápida.";
"hrv.metrics.modenn.high" = "Un modo más largo significa una frecuencia cardíaca típica más lenta.";
"hrv.metrics.modenn.reliability" = "Mejor en escaneos estándar o más largos.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Rango de intervalos";
"hrv.metrics.mxdmn.meaning" = "La diferencia entre el intervalo más largo y el más corto del escaneo.";
"hrv.metrics.mxdmn.low" = "Un rango pequeño sugiere un ritmo estable.";
"hrv.metrics.mxdmn.high" = "Un rango grande puede reflejar una alta variabilidad o artefactos.";
"hrv.metrics.mxdmn.reliability" = "Sensible a valores atípicos aislados, interprétalo con cuidado.";
"hrv.metrics.triangularindex.title" = "Índice triangular";
"hrv.metrics.triangularindex.short" = "Variabilidad general geométrica";
"hrv.metrics.triangularindex.meaning" = "El número total de intervalos dividido por la altura del pico del histograma, una medida geométrica de la variabilidad general.";
"hrv.metrics.triangularindex.low" = "Valores más bajos sugieren una variabilidad general reducida.";
"hrv.metrics.triangularindex.high" = "Valores más altos sugieren una mayor variabilidad general.";
"hrv.metrics.triangularindex.reliability" = "Requiere al menos unos minutos de latidos.";
"hrv.metrics.tinn.title" = "TINN";
"hrv.metrics.tinn.short" = "Anchura de base del histograma";
"hrv.metrics.tinn.meaning" = "La anchura de base del histograma de intervalos, otra medida geométrica de la variabilidad general.";
"hrv.metrics.tinn.low" = "Valores más bajos sugieren una variabilidad general reducida.";
"hrv.metrics.tinn.high" = "Valores más altos sugieren una mayor variabilidad general.";
"hrv.metrics.tinn.reliability" = "Requiere un escaneo más largo; se muestra solo cuando se puede estimar de forma fiable.";
"hrv.metrics.hfpower.title" = "Potencia HF";
"hrv.metrics.hfpower.short" = "Potencia de altas frecuencias";
"hrv.metrics.hfpower.meaning" = "La potencia en la banda de altas frecuencias, vinculada principalmente a la respiración y la actividad parasimpática.";
"hrv.metrics.hfpower.low" = "Una HF más baja puede acompañar al estrés o a una respiración superficial.";
"hrv.metrics.hfpower.high" = "Una HF más alta suele acompañar a una respiración tranquila y relajada.";
"hrv.metrics.hfpower.reliability" = "Requiere un escaneo profundo y una respiración constante.";
"hrv.metrics.lfpower.title" = "Potencia LF";
"hrv.metrics.lfpower.short" = "Potencia de bajas frecuencias";
"hrv.metrics.lfpower.meaning" = "La potencia en la banda de bajas frecuencias, influida por ambas ramas del sistema nervioso y por la regulación de la presión arterial.";
"hrv.metrics.lfpower.low" = "Interpreta con cuidado; muchos factores mueven este valor.";
"hrv.metrics.lfpower.high" = "Interpreta con cuidado; muchos factores mueven este valor.";
"hrv.metrics.lfpower.reliability" = "Requiere un escaneo profundo.";
"hrv.metrics.vlfpower.title" = "Potencia VLF";
"hrv.metrics.vlfpower.short" = "Potencia de muy bajas frecuencias";
"hrv.metrics.vlfpower.meaning" = "La potencia en la banda de muy bajas frecuencias, ligada a procesos de regulación más lentos.";
"hrv.metrics.vlfpower.low" = "Una VLF más baja se observa a veces con la fatiga, pero es difícil de leer en escaneos cortos.";
"hrv.metrics.vlfpower.high" = "Una VLF más alta es difícil de interpretar por sí sola.";
"hrv.metrics.vlfpower.reliability" = "Requiere un escaneo largo para tener sentido.";
"hrv.metrics.totalpower.title" = "Potencia total";
"hrv.metrics.totalpower.short" = "Potencia espectral general";
"hrv.metrics.totalpower.meaning" = "La suma de la potencia en todas las bandas de frecuencia, una medida general de la variabilidad.";
"hrv.metrics.totalpower.low" = "Una potencia total más baja sugiere una variabilidad general reducida.";
"hrv.metrics.totalpower.high" = "Una potencia total más alta sugiere una mayor variabilidad general.";
"hrv.metrics.totalpower.reliability" = "Requiere un escaneo profundo.";
"hrv.metrics.sd1.title" = "SD1";
"hrv.metrics.sd1.short" = "Anchura de Poincaré a corto plazo";
"hrv.metrics.sd1.meaning" = "La anchura de la nube de Poincaré, igual a la variabilidad a corto plazo y estrechamente ligada al RMSSD.";
"hrv.metrics.sd1.low" = "Un SD1 más bajo sugiere una variabilidad parasimpática a corto plazo reducida.";
"hrv.metrics.sd1.high" = "Un SD1 más alto sugiere más variabilidad a corto plazo, a menudo buena recuperación.";
"hrv.metrics.sd1.reliability" = "Fiable en escaneos limpios.";
"hrv.metrics.sd2.title" = "SD2";
"hrv.metrics.sd2.short" = "Longitud de Poincaré a largo plazo";
"hrv.metrics.sd2.meaning" = "La longitud de la nube de Poincaré, que refleja la variabilidad a más largo plazo.";
"hrv.metrics.sd2.low" = "Un SD2 más bajo sugiere una variabilidad a más largo plazo reducida.";
"hrv.metrics.sd2.high" = "Un SD2 más alto sugiere más variabilidad a más largo plazo.";
"hrv.metrics.sd2.reliability" = "Más fiable en escaneos más largos.";
"hrv.metrics.sd1sd2.title" = "SD1/SD2";
"hrv.metrics.sd1sd2.short" = "Equilibrio entre variabilidad a corto y largo plazo";
"hrv.metrics.sd1sd2.meaning" = "La proporción entre SD1 y SD2, que describe la forma de la nube de Poincaré.";
"hrv.metrics.sd1sd2.low" = "Una proporción más baja sugiere que domina la variabilidad a largo plazo.";
"hrv.metrics.sd1sd2.high" = "Una proporción más alta sugiere que domina la variabilidad a corto plazo.";
"hrv.metrics.sd1sd2.reliability" = "Léelo junto con SD1 y SD2.";
"hrv.metrics.sampleentropy.title" = "Entropía de muestra";
"hrv.metrics.sampleentropy.short" = "Complejidad de la señal";
"hrv.metrics.sampleentropy.meaning" = "Una medida de cuán irregular y complejo es el ritmo. Los ritmos sanos tienden a ser más complejos.";
"hrv.metrics.sampleentropy.low" = "Una complejidad muy baja puede reflejar un ritmo más rígido.";
"hrv.metrics.sampleentropy.high" = "Una mayor complejidad suele reflejar un ritmo sano y adaptable.";
"hrv.metrics.sampleentropy.reliability" = "Requiere un escaneo más largo y limpio; aún no se calcula en esta versión.";
"hrv.metrics.approximateentropy.title" = "Entropía aproximada";
"hrv.metrics.approximateentropy.short" = "Regularidad de la señal";
"hrv.metrics.approximateentropy.meaning" = "Una medida más antigua de la regularidad y complejidad del ritmo, similar en espíritu a la entropía de muestra.";
"hrv.metrics.approximateentropy.low" = "Valores más bajos sugieren un ritmo más regular y menos complejo.";
"hrv.metrics.approximateentropy.high" = "Valores más altos sugieren un ritmo más irregular y complejo.";
"hrv.metrics.approximateentropy.reliability" = "Requiere un escaneo más largo; aún no se calcula en esta versión.";
"hrv.metrics.dfaalpha1.title" = "DFA alpha1";
"hrv.metrics.dfaalpha1.short" = "Escalado fractal a corto plazo";
"hrv.metrics.dfaalpha1.meaning" = "Análisis de fluctuaciones sin tendencia en escalas cortas, que describe la estructura fractal del ritmo.";
"hrv.metrics.dfaalpha1.low" = "Valores muy por debajo de 1 sugieren una dinámica a corto plazo más aleatoria.";
"hrv.metrics.dfaalpha1.high" = "Valores cercanos o superiores a 1 sugieren una dinámica a corto plazo más correlacionada.";
"hrv.metrics.dfaalpha1.reliability" = "Requiere un escaneo más largo; aún no se calcula en esta versión.";
"hrv.metrics.dfaalpha2.title" = "DFA alpha2";
"hrv.metrics.dfaalpha2.short" = "Escalado fractal a largo plazo";
"hrv.metrics.dfaalpha2.meaning" = "Análisis de fluctuaciones sin tendencia en escalas más largas.";
"hrv.metrics.dfaalpha2.low" = "Valores más bajos sugieren una dinámica a largo plazo menos correlacionada.";
"hrv.metrics.dfaalpha2.high" = "Valores más altos sugieren una dinámica a largo plazo más correlacionada.";
"hrv.metrics.dfaalpha2.reliability" = "Requiere un escaneo largo; aún no se calcula en esta versión.";
