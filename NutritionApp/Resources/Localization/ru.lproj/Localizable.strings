"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Краткосрочная вариабельность";
"hrv.metrics.rmssd.meaning" = "RMSSD отражает изменения от удара к удару, в основном за счёт парасимпатической (восстановительной) ветви нервной системы.";
"hrv.metrics.rmssd.low" = "RMSSD ниже обычного может отражать стресс, плохой сон, болезнь или тяжёлую тренировку.";
"hrv.metrics.rmssd.high" = "Более высокий RMSSD часто отражает хорошее восстановление, хотя необычно высокие значения при усталости могут означать потребность в восстановлении.";
"hrv.metrics.rmssd.reliability" = "Надёжен даже на коротких спокойных сканах.";
"hrv.metrics.sdnn.title" = "SDNN";
