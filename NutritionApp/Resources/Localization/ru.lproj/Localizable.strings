"hrv.metrics.sdnn.high" = "Более высокий SDNN обычно отражает большую общую вариабельность.";
"hrv.metrics.sdnn.reliability" = "Надёжнее на длинных сканах.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Доля больших изменений ударов";
"hrv.metrics.pnn50.meaning" = "pNN50 — это процент соседних ударов, отличающихся более чем на 50 мс, ещё один парасимпатический маркер.";
"hrv.metrics.pnn50.low" = "Низкий pNN50 может сопровождать стресс или усталость.";
"hrv.metrics.pnn50.high" = "Более высокий pNN50 обычно сопровождает расслабленное, хорошо восстановленное состояние.";
"hrv.metrics.pnn50.reliability" = "Пригоден на коротких сканах, но шумнее RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
