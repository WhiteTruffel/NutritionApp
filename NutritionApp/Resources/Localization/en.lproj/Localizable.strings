/* ===================== HRV module ===================== */

/* HRV onboarding */
"hrv.onboarding.what_is_hrv.title" = "What is HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV means heart rate variability. It measures tiny changes in time between your heartbeats.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Your heart does not beat like a perfect metronome.";
"hrv.onboarding.what_is_hrv.bullet_2" = "A flexible rhythm can reflect better nervous-system adaptability.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV can be affected by sleep, stress, illness, training, alcohol, caffeine, hydration, and emotional pressure.";

"hrv.onboarding.camera_scan.title" = "How the phone scan works";
"hrv.onboarding.camera_scan.body" = "The camera sees tiny colour changes in your fingertip. These changes follow your pulse wave, and the app estimates the time between beats.";
"hrv.onboarding.camera_scan.bullet_1" = "This is a camera-based HRV estimate.";
"hrv.onboarding.camera_scan.bullet_2" = "It is useful for trends when measured carefully.";
"hrv.onboarding.camera_scan.bullet_3" = "It is not ECG and not a medical diagnosis.";

"hrv.onboarding.best_time.title" = "When to measure";
"hrv.onboarding.best_time.body" = "For the best trend, measure at the same time each morning before caffeine, food, training, or work stress.";
"hrv.onboarding.best_time.bullet_1" = "Measure after waking.";
"hrv.onboarding.best_time.bullet_2" = "Measure before caffeine or food.";
"hrv.onboarding.best_time.bullet_3" = "Use the same body position each day.";
"hrv.onboarding.best_time.bullet_4" = "Try to measure in the same morning time window.";

"hrv.onboarding.preparation.title" = "Before you start";
"hrv.onboarding.preparation.body" = "Stillness matters. HRV is sensitive, so the cleanest scans happen when your body is calm and your finger stays steady.";
"hrv.onboarding.preparation.bullet_1" = "Sit or lie down.";
"hrv.onboarding.preparation.bullet_2" = "Rest for one to two minutes.";
"hrv.onboarding.preparation.bullet_3" = "Warm your hands if your fingers are cold.";
"hrv.onboarding.preparation.bullet_4" = "Breathe normally and avoid talking.";

"hrv.onboarding.finger_placement.title" = "Place your finger gently";
"hrv.onboarding.finger_placement.body" = "Cover the rear camera fully with your fingertip. Use gentle, steady pressure. If you press too hard, blood flow changes and the scan becomes less reliable.";
"hrv.onboarding.finger_placement.bullet_1" = "Cover the camera fully.";
"hrv.onboarding.finger_placement.bullet_2" = "Do not press too hard.";
"hrv.onboarding.finger_placement.bullet_3" = "Keep your finger still.";

"hrv.onboarding.during_scan.title" = "During the scan";
"hrv.onboarding.during_scan.body" = "Just breathe normally. Do not try to improve the score. The goal is to capture your real state.";
"hrv.onboarding.during_scan.bullet_1" = "Stay still.";
"hrv.onboarding.during_scan.bullet_2" = "Do not talk.";
"hrv.onboarding.during_scan.bullet_3" = "Keep breathing naturally.";

"hrv.onboarding.scan_length.title" = "Choose your scan depth";
"hrv.onboarding.scan_length.body" = "Short scans are useful for daily trends. Longer scans unlock deeper HRV metrics.";
"hrv.onboarding.scan_length.bullet_1" = "Quick Scan: 60 to 120 seconds for daily readiness.";
"hrv.onboarding.scan_length.bullet_2" = "Standard Scan: 5 minutes for deeper analysis.";
"hrv.onboarding.scan_length.bullet_3" = "Deep Scan: 300 clean beats or longer for advanced HRV metrics.";

"hrv.onboarding.results.title" = "How to read your result";
"hrv.onboarding.results.body" = "One scan is a snapshot. Your personal trend is more important than one isolated value.";
"hrv.onboarding.results.bullet_1" = "Your personal baseline matters more than a generic range.";
"hrv.onboarding.results.bullet_2" = "Low HRV can reflect stress, poor sleep, illness, dehydration, alcohol, or hard training.";
"hrv.onboarding.results.bullet_3" = "High HRV can mean good recovery, but if you feel exhausted it may also reflect recovery demand.";

"hrv.onboarding.daily_guidance.title" = "Your daily guidance";
"hrv.onboarding.daily_guidance.body" = "The app uses your HRV trend to make daily reminders more personal.";
"hrv.onboarding.daily_guidance.bullet_1" = "If you measured today, reminders can include HRV-based guidance.";
"hrv.onboarding.daily_guidance.bullet_2" = "If you have not measured, reminders will gently nudge you to take a scan.";
"hrv.onboarding.daily_guidance.bullet_3" = "The more consistently you measure, the better your guidance becomes.";

"hrv.onboarding.limitations.title" = "Important limitations";
"hrv.onboarding.limitations.body" = "HRV is not a medical diagnosis. This app does not detect heart disease, arrhythmias, or medical emergencies.";
"hrv.onboarding.limitations.bullet_1" = "Camera HRV is an estimate, not ECG.";
"hrv.onboarding.limitations.bullet_2" = "Movement, cold fingers, pressure, medication, and arrhythmias can affect accuracy.";
"hrv.onboarding.limitations.bullet_3" = "If you feel chest pain, faintness, severe shortness of breath, or unusual symptoms, seek medical help.";

"hrv.onboarding.first_scan.title" = "Ready for your first scan?";
"hrv.onboarding.first_scan.body" = "Take your first calm scan now so the app can start building your personal HRV baseline.";
"hrv.onboarding.first_scan.primary_cta" = "Start HRV scan";
"hrv.onboarding.first_scan.secondary_cta" = "Remind me later";

