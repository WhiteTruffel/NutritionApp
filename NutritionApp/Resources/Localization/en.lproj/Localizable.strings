/* HRV metric glossary (core metrics; remaining metrics pending content) */
"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Short-term variability";
"hrv.metrics.rmssd.meaning" = "RMSSD reflects beat-to-beat changes driven mainly by the parasympathetic (recovery) branch of your nervous system.";
"hrv.metrics.rmssd.low" = "Lower RMSSD than usual can reflect stress, poor sleep, illness, or hard training.";
"hrv.metrics.rmssd.high" = "Higher RMSSD often reflects good recovery, though unusually high values with fatigue can mean recovery demand.";
"hrv.metrics.rmssd.reliability" = "Reliable even on short, calm scans.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Overall variability";
"hrv.metrics.sdnn.meaning" = "SDNN captures the overall spread of your interval lengths, reflecting both branches of your nervous system.";
"hrv.metrics.sdnn.low" = "Lower SDNN can reflect reduced overall adaptability.";
"hrv.metrics.sdnn.high" = "Higher SDNN generally reflects greater overall variability.";
"hrv.metrics.sdnn.reliability" = "More reliable on longer scans.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Share of large beat changes";
"hrv.metrics.pnn50.meaning" = "pNN50 is the percentage of adjacent beats that differ by more than 50 ms, another parasympathetic marker.";
"hrv.metrics.pnn50.low" = "A low pNN50 can accompany stress or fatigue.";
"hrv.metrics.pnn50.high" = "A higher pNN50 usually accompanies relaxed, well-recovered states.";
"hrv.metrics.pnn50.reliability" = "Usable on short scans, but noisier than RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Beat clustering";
"hrv.metrics.amo50.meaning" = "AMo50 describes how tightly your intervals cluster around the most common value; tighter clustering suggests more sympathetic activation.";
"hrv.metrics.amo50.low" = "A lower AMo50 suggests a more relaxed, variable rhythm.";
"hrv.metrics.amo50.high" = "A higher AMo50 suggests a stiffer, more activated rhythm.";
"hrv.metrics.amo50.reliability" = "Best on standard or longer scans.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Frequency balance (context only)";
"hrv.metrics.lfhf.meaning" = "LF/HF compares low and high frequency power. It is easy to misread, so this app treats it only as supporting context, never as a simple stress meter.";
"hrv.metrics.lfhf.low" = "Interpret with caution; many factors move this ratio.";
"hrv.metrics.lfhf.high" = "Interpret with caution; many factors move this ratio.";
"hrv.metrics.lfhf.reliability" = "Needs a deep scan and is sensitive to breathing.";

/* HRV metric glossary (remaining metrics) */
"hrv.metrics.hr.title" = "Heart Rate";
"hrv.metrics.hr.short" = "Beats per minute";
"hrv.metrics.hr.meaning" = "Average heart rate during the scan, derived from the mean time between beats.";
"hrv.metrics.hr.low" = "A lower resting heart rate often goes with good fitness and recovery.";
"hrv.metrics.hr.high" = "A higher than usual heart rate can reflect stress, stimulants, illness, or poor recovery.";
"hrv.metrics.hr.reliability" = "Reliable on any clean scan.";
"hrv.metrics.meannn.title" = "Mean NN";
"hrv.metrics.meannn.short" = "Average beat interval";
"hrv.metrics.meannn.meaning" = "The average time between heartbeats in milliseconds. It is the inverse of heart rate.";
"hrv.metrics.meannn.low" = "Shorter intervals mean a faster heart rate.";
"hrv.metrics.meannn.high" = "Longer intervals mean a slower heart rate.";
"hrv.metrics.meannn.reliability" = "Reliable on any clean scan.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "Log scaled RMSSD";
"hrv.metrics.lnrmssd.meaning" = "The natural log of RMSSD. It compresses the range so day to day trends are easier to compare.";
"hrv.metrics.lnrmssd.low" = "Lower values track with lower RMSSD, often stress or fatigue.";
"hrv.metrics.lnrmssd.high" = "Higher values track with higher RMSSD, often good recovery.";
"hrv.metrics.lnrmssd.reliability" = "Preferred for trend analytics because it is more stable.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Count of large beat changes";
"hrv.metrics.nn50.meaning" = "The number of adjacent beats that differ by more than 50 ms.";
"hrv.metrics.nn50.low" = "A low count can accompany stress or fatigue.";
"hrv.metrics.nn50.high" = "A higher count usually accompanies a relaxed, well recovered state.";
"hrv.metrics.nn50.reliability" = "Usable on short scans, but noisier than RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Spread of beat to beat changes";
"hrv.metrics.sdsd.meaning" = "The standard deviation of the differences between adjacent beats, a short term variability measure.";
"hrv.metrics.sdsd.low" = "Lower SDSD suggests reduced short term variability.";
"hrv.metrics.sdsd.high" = "Higher SDSD suggests more short term variability, often good recovery.";
"hrv.metrics.sdsd.reliability" = "Usable on short, calm scans.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Relative overall variability";
"hrv.metrics.cvnn.meaning" = "SDNN divided by the mean interval, so variability is expressed relative to heart rate.";
"hrv.metrics.cvnn.low" = "Lower CVNN suggests reduced relative variability.";
"hrv.metrics.cvnn.high" = "Higher CVNN suggests greater relative variability.";
"hrv.metrics.cvnn.reliability" = "More reliable on longer scans.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Relative short term variability";
"hrv.metrics.cvsd.meaning" = "RMSSD divided by the mean interval, short term variability relative to heart rate.";
"hrv.metrics.cvsd.low" = "Lower CVSD suggests reduced relative short term variability.";
"hrv.metrics.cvsd.high" = "Higher CVSD suggests more relative short term variability.";
"hrv.metrics.cvsd.reliability" = "Usable on short scans.";
"hrv.metrics.modenn.title" = "Mode NN";
"hrv.metrics.modenn.short" = "Most common beat interval";
"hrv.metrics.modenn.meaning" = "The most frequent interval length, the centre of the tallest histogram bar.";
"hrv.metrics.modenn.low" = "A shorter mode means a faster typical heart rate.";
"hrv.metrics.modenn.high" = "A longer mode means a slower typical heart rate.";
"hrv.metrics.modenn.reliability" = "Best on standard or longer scans.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Range of intervals";
"hrv.metrics.mxdmn.meaning" = "The difference between the longest and shortest interval in the scan.";
"hrv.metrics.mxdmn.low" = "A small range suggests a steady rhythm.";
"hrv.metrics.mxdmn.high" = "A large range can reflect high variability or artifacts.";
"hrv.metrics.mxdmn.reliability" = "Sensitive to single outliers, read with care.";
"hrv.metrics.triangularindex.title" = "Triangular Index";
"hrv.metrics.triangularindex.short" = "Geometric overall variability";
"hrv.metrics.triangularindex.meaning" = "The total number of intervals divided by the height of the histogram peak, a geometric measure of overall variability.";
"hrv.metrics.triangularindex.low" = "Lower values suggest reduced overall variability.";
"hrv.metrics.triangularindex.high" = "Higher values suggest greater overall variability.";
"hrv.metrics.triangularindex.reliability" = "Needs at least a few minutes of beats.";
"hrv.metrics.tinn.title" = "TINN";
"hrv.metrics.tinn.short" = "Histogram base width";
"hrv.metrics.tinn.meaning" = "The baseline width of the interval histogram, another geometric measure of overall variability.";
"hrv.metrics.tinn.low" = "Lower values suggest reduced overall variability.";
"hrv.metrics.tinn.high" = "Higher values suggest greater overall variability.";
"hrv.metrics.tinn.reliability" = "Needs a longer scan; shown only when it can be estimated reliably.";
"hrv.metrics.hfpower.title" = "HF Power";
"hrv.metrics.hfpower.short" = "High frequency power";
"hrv.metrics.hfpower.meaning" = "Power in the high frequency band, linked mainly to breathing and parasympathetic activity.";
"hrv.metrics.hfpower.low" = "Lower HF can accompany stress or shallow breathing.";
"hrv.metrics.hfpower.high" = "Higher HF often accompanies calm, relaxed breathing.";
"hrv.metrics.hfpower.reliability" = "Needs a deep scan and steady breathing.";
"hrv.metrics.lfpower.title" = "LF Power";
"hrv.metrics.lfpower.short" = "Low frequency power";
"hrv.metrics.lfpower.meaning" = "Power in the low frequency band, influenced by both branches of the nervous system and by blood pressure regulation.";
"hrv.metrics.lfpower.low" = "Interpret with care; many factors move this value.";
"hrv.metrics.lfpower.high" = "Interpret with care; many factors move this value.";
"hrv.metrics.lfpower.reliability" = "Needs a deep scan.";
"hrv.metrics.vlfpower.title" = "VLF Power";
"hrv.metrics.vlfpower.short" = "Very low frequency power";
"hrv.metrics.vlfpower.meaning" = "Power in the very low frequency band, tied to slower regulatory processes.";
"hrv.metrics.vlfpower.low" = "Lower VLF is sometimes seen with strain, but it is hard to read from short scans.";
"hrv.metrics.vlfpower.high" = "Higher VLF is hard to interpret on its own.";
"hrv.metrics.vlfpower.reliability" = "Needs a long scan to be meaningful.";
"hrv.metrics.totalpower.title" = "Total Power";
"hrv.metrics.totalpower.short" = "Overall spectral power";
"hrv.metrics.totalpower.meaning" = "The sum of power across all frequency bands, an overall measure of variability.";
"hrv.metrics.totalpower.low" = "Lower total power suggests reduced overall variability.";
"hrv.metrics.totalpower.high" = "Higher total power suggests greater overall variability.";
"hrv.metrics.totalpower.reliability" = "Needs a deep scan.";
"hrv.metrics.sd1.title" = "SD1";
"hrv.metrics.sd1.short" = "Short term Poincare width";
"hrv.metrics.sd1.meaning" = "The width of the Poincare cloud, equal to short term variability and closely tied to RMSSD.";
"hrv.metrics.sd1.low" = "Lower SD1 suggests reduced short term, parasympathetic variability.";
"hrv.metrics.sd1.high" = "Higher SD1 suggests more short term variability, often good recovery.";
"hrv.metrics.sd1.reliability" = "Reliable on clean scans.";
"hrv.metrics.sd2.title" = "SD2";
"hrv.metrics.sd2.short" = "Long term Poincare length";
"hrv.metrics.sd2.meaning" = "The length of the Poincare cloud, reflecting longer term variability.";
"hrv.metrics.sd2.low" = "Lower SD2 suggests reduced longer term variability.";
"hrv.metrics.sd2.high" = "Higher SD2 suggests more longer term variability.";
"hrv.metrics.sd2.reliability" = "More reliable on longer scans.";
"hrv.metrics.sd1sd2.title" = "SD1/SD2";
"hrv.metrics.sd1sd2.short" = "Balance of short to long variability";
"hrv.metrics.sd1sd2.meaning" = "The ratio of SD1 to SD2, describing the shape of the Poincare cloud.";
"hrv.metrics.sd1sd2.low" = "A lower ratio suggests longer term variability dominates.";
"hrv.metrics.sd1sd2.high" = "A higher ratio suggests short term variability dominates.";
"hrv.metrics.sd1sd2.reliability" = "Read together with SD1 and SD2.";
"hrv.metrics.sampleentropy.title" = "Sample Entropy";
"hrv.metrics.sampleentropy.short" = "Signal complexity";
"hrv.metrics.sampleentropy.meaning" = "A measure of how irregular and complex the rhythm is. Healthy rhythms tend to be more complex.";
"hrv.metrics.sampleentropy.low" = "Very low complexity can reflect a more rigid rhythm.";
"hrv.metrics.sampleentropy.high" = "Higher complexity often reflects a healthy, adaptable rhythm.";
"hrv.metrics.sampleentropy.reliability" = "Needs a longer, clean scan; not yet computed in this version.";
"hrv.metrics.approximateentropy.title" = "Approximate Entropy";
"hrv.metrics.approximateentropy.short" = "Signal regularity";
"hrv.metrics.approximateentropy.meaning" = "An older measure of rhythm regularity and complexity, similar in spirit to sample entropy.";
"hrv.metrics.approximateentropy.low" = "Lower values suggest a more regular, less complex rhythm.";
"hrv.metrics.approximateentropy.high" = "Higher values suggest a more irregular, complex rhythm.";
"hrv.metrics.approximateentropy.reliability" = "Needs a longer scan; not yet computed in this version.";
"hrv.metrics.dfaalpha1.title" = "DFA alpha1";
"hrv.metrics.dfaalpha1.short" = "Short term fractal scaling";
"hrv.metrics.dfaalpha1.meaning" = "Detrended fluctuation analysis over short scales, describing the fractal structure of the rhythm.";
"hrv.metrics.dfaalpha1.low" = "Values well below 1 suggest more random short term dynamics.";
"hrv.metrics.dfaalpha1.high" = "Values near or above 1 suggest more correlated short term dynamics.";
"hrv.metrics.dfaalpha1.reliability" = "Needs a longer scan; not yet computed in this version.";
"hrv.metrics.dfaalpha2.title" = "DFA alpha2";
"hrv.metrics.dfaalpha2.short" = "Long term fractal scaling";
"hrv.metrics.dfaalpha2.meaning" = "Detrended fluctuation analysis over longer scales.";
"hrv.metrics.dfaalpha2.low" = "Lower values suggest less correlated long term dynamics.";
"hrv.metrics.dfaalpha2.high" = "Higher values suggest more correlated long term dynamics.";
"hrv.metrics.dfaalpha2.reliability" = "Needs a long scan; not yet computed in this version.";
