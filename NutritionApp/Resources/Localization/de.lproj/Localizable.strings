/* HRV Onboarding */
"hrv.onboarding.what_is_hrv.title" = "Was ist HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV bedeutet Herzratenvariabilität. Sie misst die kleinen Zeitunterschiede zwischen deinen Herzschlägen.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Dein Herz schlägt nicht wie ein perfektes Metronom.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Ein flexibler Rhythmus kann auf eine bessere Anpassungsfähigkeit deines Nervensystems hinweisen.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV kann durch Schlaf, Stress, Krankheit, Training, Alkohol, Koffein, Hydration und emotionale Belastung beeinflusst werden.";

"hrv.onboarding.camera_scan.title" = "Wie die Messung mit dem Smartphone funktioniert";
"hrv.onboarding.camera_scan.body" = "Die Kamera erkennt kleinste Farbveränderungen in deiner Fingerspitze. Diese Veränderungen folgen deiner Pulswelle, und die App schätzt daraus die Zeit zwischen den Herzschlägen.";
"hrv.onboarding.camera_scan.bullet_1" = "Das ist eine kamerabasierte HRV-Schätzung.";
"hrv.onboarding.camera_scan.bullet_2" = "Sie ist nützlich für Trends, wenn du sorgfältig misst.";
"hrv.onboarding.camera_scan.bullet_3" = "Sie ist kein EKG und keine medizinische Diagnose.";

"hrv.onboarding.best_time.title" = "Wann du messen solltest";
"hrv.onboarding.best_time.body" = "Für den besten Trend misst du möglichst jeden Morgen zur gleichen Zeit, bevor Koffein, Essen, Training oder Arbeitsstress beginnen.";
"hrv.onboarding.best_time.bullet_1" = "Miss nach dem Aufwachen.";
"hrv.onboarding.best_time.bullet_2" = "Miss vor Koffein oder Essen.";
"hrv.onboarding.best_time.bullet_3" = "Nutze jeden Tag die gleiche Körperposition.";
"hrv.onboarding.best_time.bullet_4" = "Miss möglichst im gleichen morgendlichen Zeitfenster.";

"hrv.onboarding.preparation.title" = "Bevor du startest";
"hrv.onboarding.preparation.body" = "Ruhe ist wichtig. HRV ist empfindlich, deshalb entstehen die saubersten Messungen, wenn dein Körper ruhig ist und dein Finger stabil bleibt.";
"hrv.onboarding.preparation.bullet_1" = "Setze oder lege dich hin.";
"hrv.onboarding.preparation.bullet_2" = "Ruh dich ein bis zwei Minuten aus.";
"hrv.onboarding.preparation.bullet_3" = "Wärme deine Hände, wenn deine Finger kalt sind.";
"hrv.onboarding.preparation.bullet_4" = "Atme normal und sprich nicht während der Messung.";

"hrv.onboarding.finger_placement.title" = "Lege deinen Finger sanft auf";
"hrv.onboarding.finger_placement.body" = "Bedecke die Rückkamera vollständig mit deiner Fingerspitze. Nutze sanften, gleichmäßigen Druck. Wenn du zu stark drückst, verändert sich der Blutfluss und die Messung wird weniger zuverlässig.";
"hrv.onboarding.finger_placement.bullet_1" = "Bedecke die Kamera vollständig.";
"hrv.onboarding.finger_placement.bullet_2" = "Drücke nicht zu stark.";
"hrv.onboarding.finger_placement.bullet_3" = "Halte den Finger still.";

"hrv.onboarding.during_scan.title" = "Während der Messung";
"hrv.onboarding.during_scan.body" = "Atme einfach normal. Versuche nicht, den Wert zu verbessern. Ziel ist es, deinen echten Zustand zu erfassen.";
"hrv.onboarding.during_scan.bullet_1" = "Bleib still.";
"hrv.onboarding.during_scan.bullet_2" = "Sprich nicht.";
"hrv.onboarding.during_scan.bullet_3" = "Atme natürlich weiter.";

"hrv.onboarding.scan_length.title" = "Wähle die Messtiefe";
"hrv.onboarding.scan_length.body" = "Kurze Messungen sind nützlich für tägliche Trends. Längere Messungen schalten tiefere HRV-Metriken frei.";
"hrv.onboarding.scan_length.bullet_1" = "Quick Scan: 60 bis 120 Sekunden für tägliche Bereitschaft.";
"hrv.onboarding.scan_length.bullet_2" = "Standard Scan: 5 Minuten für tiefere Analyse.";
"hrv.onboarding.scan_length.bullet_3" = "Deep Scan: 300 saubere Herzschläge oder länger für fortgeschrittene HRV-Metriken.";

"hrv.onboarding.results.title" = "Wie du dein Ergebnis liest";
"hrv.onboarding.results.body" = "Eine Messung ist eine Momentaufnahme. Dein persönlicher Trend ist wichtiger als ein einzelner Wert.";
"hrv.onboarding.results.bullet_1" = "Deine persönliche Basislinie ist wichtiger als ein allgemeiner Normalbereich.";
"hrv.onboarding.results.bullet_2" = "Niedrige HRV kann durch Stress, schlechten Schlaf, Krankheit, Dehydration, Alkohol oder hartes Training entstehen.";
"hrv.onboarding.results.bullet_3" = "Hohe HRV kann gute Erholung bedeuten. Wenn du dich erschöpft fühlst, kann sie aber auch auf Erholungsbedarf hinweisen.";

"hrv.onboarding.daily_guidance.title" = "Deine tägliche Orientierung";
"hrv.onboarding.daily_guidance.body" = "Die App nutzt deinen HRV-Trend, um tägliche Erinnerungen persönlicher zu machen.";
"hrv.onboarding.daily_guidance.bullet_1" = "Wenn du heute gemessen hast, können Erinnerungen HRV-basierte Hinweise enthalten.";
"hrv.onboarding.daily_guidance.bullet_2" = "Wenn du noch nicht gemessen hast, erinnert dich die App sanft an eine Messung.";
"hrv.onboarding.daily_guidance.bullet_3" = "Je regelmäßiger du misst, desto persönlicher wird deine Orientierung.";

"hrv.onboarding.limitations.title" = "Wichtige Grenzen";
"hrv.onboarding.limitations.body" = "HRV ist keine medizinische Diagnose. Diese App erkennt keine Herzerkrankungen, Rhythmusstörungen oder medizinischen Notfälle.";
"hrv.onboarding.limitations.bullet_1" = "Kamera-HRV ist eine Schätzung, kein EKG.";
"hrv.onboarding.limitations.bullet_2" = "Bewegung, kalte Finger, Druck, Medikamente und Rhythmusstörungen können die Genauigkeit beeinflussen.";
"hrv.onboarding.limitations.bullet_3" = "Bei Brustschmerzen, Ohnmacht, starker Atemnot oder ungewöhnlichen Symptomen solltest du medizinische Hilfe suchen.";

"hrv.onboarding.first_scan.title" = "Bereit für deine erste Messung?";
"hrv.onboarding.first_scan.body" = "Mach jetzt deine erste ruhige Messung, damit die App deine persönliche HRV-Basislinie aufbauen kann.";
"hrv.onboarding.first_scan.primary_cta" = "HRV-Messung starten";
"hrv.onboarding.first_scan.secondary_cta" = "Später erinnern";

