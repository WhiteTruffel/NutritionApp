/* HRV Metrik-Glossar (Kernmetriken; weitere Metriken folgen) */
"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Kurzfristige Variabilität";
"hrv.metrics.rmssd.meaning" = "RMSSD spiegelt Schlag-zu-Schlag-Änderungen wider, die vor allem vom parasympathischen (Erholungs-) Teil deines Nervensystems gesteuert werden.";
"hrv.metrics.rmssd.low" = "Ein niedrigerer RMSSD als gewöhnlich kann auf Stress, schlechten Schlaf, Krankheit oder hartes Training hinweisen.";
"hrv.metrics.rmssd.high" = "Ein höherer RMSSD spiegelt oft gute Erholung wider. Ungewöhnlich hohe Werte mit Müdigkeit können jedoch Erholungsbedarf bedeuten.";
"hrv.metrics.rmssd.reliability" = "Auch bei kurzen, ruhigen Messungen zuverlässig.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Gesamtvariabilität";
"hrv.metrics.sdnn.meaning" = "SDNN erfasst die gesamte Streuung deiner Intervalllängen und spiegelt beide Teile deines Nervensystems wider.";
"hrv.metrics.sdnn.low" = "Ein niedrigerer SDNN kann auf geringere Gesamtanpassungsfähigkeit hinweisen.";
"hrv.metrics.sdnn.high" = "Ein höherer SDNN spiegelt in der Regel eine größere Gesamtvariabilität wider.";
"hrv.metrics.sdnn.reliability" = "Bei längeren Messungen zuverlässiger.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Anteil großer Schlagänderungen";
"hrv.metrics.pnn50.meaning" = "pNN50 ist der Prozentsatz benachbarter Schläge, die sich um mehr als 50 ms unterscheiden, ein weiterer parasympathischer Marker.";
"hrv.metrics.pnn50.low" = "Ein niedriger pNN50 kann mit Stress oder Müdigkeit einhergehen.";
"hrv.metrics.pnn50.high" = "Ein höherer pNN50 geht meist mit entspannten, gut erholten Zuständen einher.";
"hrv.metrics.pnn50.reliability" = "Bei kurzen Messungen nutzbar, aber unruhiger als RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Schlagbündelung";
"hrv.metrics.amo50.meaning" = "AMo50 beschreibt, wie eng deine Intervalle um den häufigsten Wert gruppiert sind. Engere Bündelung deutet auf stärkere sympathische Aktivierung hin.";
"hrv.metrics.amo50.low" = "Ein niedrigerer AMo50 deutet auf einen entspannteren, variableren Rhythmus hin.";
"hrv.metrics.amo50.high" = "Ein höherer AMo50 deutet auf einen steiferen, aktivierten Rhythmus hin.";
"hrv.metrics.amo50.reliability" = "Am besten bei Standard- oder längeren Messungen.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Frequenzbalance (nur Kontext)";
"hrv.metrics.lfhf.meaning" = "LF/HF vergleicht niedrige und hohe Frequenzleistung. Es ist leicht falsch zu deuten, daher behandelt diese App es nur als unterstützenden Kontext, nie als einfaches Stressmaß.";
"hrv.metrics.lfhf.low" = "Mit Vorsicht deuten; viele Faktoren bewegen dieses Verhältnis.";
"hrv.metrics.lfhf.high" = "Mit Vorsicht deuten; viele Faktoren bewegen dieses Verhältnis.";
"hrv.metrics.lfhf.reliability" = "Benötigt eine tiefe Messung und ist empfindlich gegenüber der Atmung.";

/* HRV Metrik-Glossar (weitere Metriken) */
"hrv.metrics.hr.title" = "Herzfrequenz";
"hrv.metrics.hr.short" = "Schläge pro Minute";
"hrv.metrics.hr.meaning" = "Durchschnittliche Herzfrequenz während der Messung, abgeleitet aus der mittleren Zeit zwischen den Schlägen.";
"hrv.metrics.hr.low" = "Eine niedrigere Ruheherzfrequenz geht oft mit guter Fitness und Erholung einher.";
"hrv.metrics.hr.high" = "Eine höhere Herzfrequenz als gewöhnlich kann auf Stress, Stimulanzien, Krankheit oder schlechte Erholung hinweisen.";
"hrv.metrics.hr.reliability" = "Bei jeder sauberen Messung zuverlässig.";
"hrv.metrics.meannn.title" = "Mean NN";
"hrv.metrics.meannn.short" = "Mittleres Schlagintervall";
"hrv.metrics.meannn.meaning" = "Die durchschnittliche Zeit zwischen Herzschlägen in Millisekunden. Sie ist der Kehrwert der Herzfrequenz.";
"hrv.metrics.meannn.low" = "Kürzere Intervalle bedeuten eine höhere Herzfrequenz.";
"hrv.metrics.meannn.high" = "Längere Intervalle bedeuten eine niedrigere Herzfrequenz.";
"hrv.metrics.meannn.reliability" = "Bei jeder sauberen Messung zuverlässig.";
"hrv.metrics.lnrmssd.title" = "ln RMSSD";
"hrv.metrics.lnrmssd.short" = "Logarithmierter RMSSD";
"hrv.metrics.lnrmssd.meaning" = "Der natürliche Logarithmus von RMSSD. Er staucht den Wertebereich, damit Trends von Tag zu Tag leichter vergleichbar sind.";
"hrv.metrics.lnrmssd.low" = "Niedrigere Werte gehen mit niedrigerem RMSSD einher, oft Stress oder Müdigkeit.";
"hrv.metrics.lnrmssd.high" = "Höhere Werte gehen mit höherem RMSSD einher, oft gute Erholung.";
"hrv.metrics.lnrmssd.reliability" = "Für Trendauswertungen bevorzugt, da stabiler.";
"hrv.metrics.nn50.title" = "NN50";
"hrv.metrics.nn50.short" = "Anzahl großer Schlagänderungen";
"hrv.metrics.nn50.meaning" = "Die Anzahl benachbarter Schläge, die sich um mehr als 50 ms unterscheiden.";
"hrv.metrics.nn50.low" = "Eine niedrige Anzahl kann mit Stress oder Müdigkeit einhergehen.";
"hrv.metrics.nn50.high" = "Eine höhere Anzahl geht meist mit einem entspannten, gut erholten Zustand einher.";
"hrv.metrics.nn50.reliability" = "Bei kurzen Messungen nutzbar, aber unruhiger als RMSSD.";
"hrv.metrics.sdsd.title" = "SDSD";
"hrv.metrics.sdsd.short" = "Streuung der Schlag zu Schlag Änderungen";
"hrv.metrics.sdsd.meaning" = "Die Standardabweichung der Differenzen zwischen benachbarten Schlägen, ein Maß für kurzfristige Variabilität.";
"hrv.metrics.sdsd.low" = "Ein niedrigerer SDSD deutet auf geringere kurzfristige Variabilität hin.";
"hrv.metrics.sdsd.high" = "Ein höherer SDSD deutet auf mehr kurzfristige Variabilität hin, oft gute Erholung.";
"hrv.metrics.sdsd.reliability" = "Bei kurzen, ruhigen Messungen nutzbar.";
"hrv.metrics.cvnn.title" = "CVNN";
"hrv.metrics.cvnn.short" = "Relative Gesamtvariabilität";
"hrv.metrics.cvnn.meaning" = "SDNN geteilt durch das mittlere Intervall, sodass die Variabilität relativ zur Herzfrequenz ausgedrückt wird.";
"hrv.metrics.cvnn.low" = "Ein niedrigerer CVNN deutet auf geringere relative Variabilität hin.";
"hrv.metrics.cvnn.high" = "Ein höherer CVNN deutet auf größere relative Variabilität hin.";
"hrv.metrics.cvnn.reliability" = "Bei längeren Messungen zuverlässiger.";
"hrv.metrics.cvsd.title" = "CVSD";
"hrv.metrics.cvsd.short" = "Relative kurzfristige Variabilität";
"hrv.metrics.cvsd.meaning" = "RMSSD geteilt durch das mittlere Intervall, kurzfristige Variabilität relativ zur Herzfrequenz.";
"hrv.metrics.cvsd.low" = "Ein niedrigerer CVSD deutet auf geringere relative kurzfristige Variabilität hin.";
"hrv.metrics.cvsd.high" = "Ein höherer CVSD deutet auf mehr relative kurzfristige Variabilität hin.";
"hrv.metrics.cvsd.reliability" = "Bei kurzen Messungen nutzbar.";
"hrv.metrics.modenn.title" = "Mode NN";
"hrv.metrics.modenn.short" = "Häufigstes Schlagintervall";
"hrv.metrics.modenn.meaning" = "Die häufigste Intervalllänge, die Mitte des höchsten Histogrammbalkens.";
"hrv.metrics.modenn.low" = "Ein kürzeres Maximum bedeutet eine höhere typische Herzfrequenz.";
"hrv.metrics.modenn.high" = "Ein längeres Maximum bedeutet eine niedrigere typische Herzfrequenz.";
"hrv.metrics.modenn.reliability" = "Am besten bei Standard oder längeren Messungen.";
"hrv.metrics.mxdmn.title" = "MxDMn";
"hrv.metrics.mxdmn.short" = "Spannweite der Intervalle";
"hrv.metrics.mxdmn.meaning" = "Die Differenz zwischen dem längsten und dem kürzesten Intervall der Messung.";
"hrv.metrics.mxdmn.low" = "Eine kleine Spannweite deutet auf einen gleichmäßigen Rhythmus hin.";
"hrv.metrics.mxdmn.high" = "Eine große Spannweite kann auf hohe Variabilität oder Artefakte hinweisen.";
"hrv.metrics.mxdmn.reliability" = "Empfindlich gegenüber einzelnen Ausreißern, mit Vorsicht lesen.";
"hrv.metrics.triangularindex.title" = "Triangulärer Index";
"hrv.metrics.triangularindex.short" = "Geometrische Gesamtvariabilität";
