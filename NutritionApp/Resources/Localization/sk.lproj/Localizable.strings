"hrv.onboarding.what_is_hrv.title" = "Čo je HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV znamená variabilitu srdcového rytmu. Meria drobné zmeny v čase medzi vašimi srdcovými údermi.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Vaše srdce nebije ako dokonalý metronóm.";
"hrv.onboarding.what_is_hrv.bullet_2" = "Pružný rytmus môže odrážať lepšiu prispôsobivosť nervového systému.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV môžu ovplyvniť spánok, stres, choroba, tréning, alkohol, kofeín, hydratácia a emočný tlak.";
"hrv.onboarding.camera_scan.title" = "Ako funguje sken telefónom";
"hrv.onboarding.camera_scan.body" = "Kamera vidí drobné zmeny farby na vašom brušku prsta. Tieto zmeny sledujú vašu pulznú vlnu a aplikácia odhaduje čas medzi údermi.";
"hrv.onboarding.camera_scan.bullet_1" = "Toto je odhad HRV pomocou kamery.";
"hrv.onboarding.camera_scan.bullet_2" = "Je užitočný pre trendy, ak meriate dôkladne.";
"hrv.onboarding.camera_scan.bullet_3" = "Nie je to EKG ani lekárska diagnóza.";
"hrv.onboarding.best_time.title" = "Kedy merať";
"hrv.onboarding.best_time.body" = "Pre najlepší trend merajte každé ráno v rovnakom čase pred kofeínom, jedlom, tréningom alebo pracovným stresom.";
"hrv.onboarding.best_time.bullet_1" = "Merajte po prebudení.";
"hrv.onboarding.best_time.bullet_2" = "Merajte pred kofeínom alebo jedlom.";
"hrv.onboarding.best_time.bullet_3" = "Každý deň používajte rovnakú polohu tela.";
"hrv.onboarding.best_time.bullet_4" = "Snažte sa merať v rovnakom rannom časovom okne.";
"hrv.onboarding.preparation.title" = "Než začnete";
"hrv.onboarding.preparation.body" = "Pokoj je dôležitý. HRV je citlivé, takže najčistejšie skeny vznikajú, keď je telo pokojné a prst zostáva nehybný.";
"hrv.onboarding.preparation.bullet_1" = "Sadnite si alebo si ľahnite.";
"hrv.onboarding.preparation.bullet_2" = "Oddýchnite si jednu až dve minúty.";
"hrv.onboarding.preparation.bullet_3" = "Ak máte studené prsty, zahrejte si ruky.";
"hrv.onboarding.preparation.bullet_4" = "Dýchajte normálne a nehovorte.";
"hrv.onboarding.finger_placement.title" = "Jemne priložte prst";
"hrv.onboarding.finger_placement.body" = "Úplne zakryte zadnú kameru bruškom prsta. Použite jemný, rovnomerný tlak. Ak tlačíte príliš silno, mení sa prietok krvi a sken je menej spoľahlivý.";
"hrv.onboarding.finger_placement.bullet_1" = "Úplne zakryte kameru.";
"hrv.onboarding.finger_placement.bullet_2" = "Netlačte príliš silno.";
"hrv.onboarding.finger_placement.bullet_3" = "Držte prst v pokoji.";
"hrv.onboarding.during_scan.title" = "Počas skenu";
"hrv.onboarding.during_scan.body" = "Len normálne dýchajte. Nesnažte sa skóre zlepšiť. Cieľom je zachytiť váš skutočný stav.";
"hrv.onboarding.during_scan.bullet_1" = "Zostaňte v pokoji.";
"hrv.onboarding.during_scan.bullet_2" = "Nehovorte.";
"hrv.onboarding.during_scan.bullet_3" = "Dýchajte prirodzene.";
"hrv.onboarding.scan_length.title" = "Vyberte hĺbku skenu";
"hrv.onboarding.scan_length.body" = "Krátke skeny sú užitočné pre denné trendy. Dlhšie skeny odomykajú hlbšie metriky HRV.";
"hrv.onboarding.scan_length.bullet_1" = "Rýchly sken: 60 až 120 sekúnd pre dennú pripravenosť.";
"hrv.onboarding.scan_length.bullet_2" = "Štandardný sken: 5 minút pre hlbšiu analýzu.";
"hrv.onboarding.scan_length.bullet_3" = "Hlboký sken: 300 čistých úderov alebo viac pre pokročilé metriky HRV.";
"hrv.onboarding.results.title" = "Ako čítať výsledok";
"hrv.onboarding.results.body" = "Jeden sken je momentka. Váš osobný trend je dôležitejší ako jediná hodnota.";
"hrv.onboarding.results.bullet_1" = "Vaša osobná východisková hodnota znamená viac ako všeobecné rozpätie.";
"hrv.onboarding.results.bullet_2" = "Nízke HRV môže odrážať stres, zlý spánok, chorobu, dehydratáciu, alkohol alebo tvrdý tréning.";
"hrv.onboarding.results.bullet_3" = "Vysoké HRV môže znamenať dobrú regeneráciu, ale ak sa cítite vyčerpaní, môže odrážať aj potrebu regenerácie.";
"hrv.onboarding.daily_guidance.title" = "Vaše denné rady";
"hrv.onboarding.daily_guidance.body" = "Aplikácia používa váš trend HRV, aby boli denné pripomenutia osobnejšie.";
"hrv.onboarding.daily_guidance.bullet_1" = "Ak ste dnes merali, pripomenutia môžu obsahovať rady založené na HRV.";
"hrv.onboarding.daily_guidance.bullet_2" = "Ak ste nemerali, pripomenutia vás jemne pobádajú k skenu.";
"hrv.onboarding.daily_guidance.bullet_3" = "Čím pravidelnejšie meriate, tým lepšie sú vaše rady.";
"hrv.onboarding.limitations.title" = "Dôležité obmedzenia";
"hrv.onboarding.limitations.body" = "HRV nie je lekárska diagnóza. Táto aplikácia nezisťuje srdcové ochorenia, arytmie ani naliehavé stavy.";
"hrv.onboarding.limitations.bullet_1" = "HRV z kamery je odhad, nie EKG.";
"hrv.onboarding.limitations.bullet_2" = "Pohyb, studené prsty, tlak, lieky a arytmie môžu ovplyvniť presnosť.";
"hrv.onboarding.limitations.bullet_3" = "Pri bolesti na hrudi, mdlobách, silnej dýchavičnosti alebo nezvyčajných príznakoch vyhľadajte lekársku pomoc.";
"hrv.onboarding.first_scan.title" = "Pripravení na prvý sken?";
"hrv.onboarding.first_scan.body" = "Urobte teraz prvý pokojný sken, aby aplikácia mohla začať budovať vašu osobnú východiskovú hodnotu HRV.";
