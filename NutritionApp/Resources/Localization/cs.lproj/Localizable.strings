"hrv.onboarding.what_is_hrv.title" = "Co je HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV znamená variabilitu srdečního rytmu. Měří drobné změny v čase mezi vašimi srdečními tepy.";
