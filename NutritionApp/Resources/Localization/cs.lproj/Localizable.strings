"hrv.onboarding.camera_scan.title" = "Jak funguje sken telefonem";
"hrv.onboarding.camera_scan.body" = "Kamera vidí drobné změny barvy na vaší bříšku prstu. Tyto změny sledují vaši pulzní vlnu a aplikace odhaduje čas mezi tepy.";
"hrv.onboarding.camera_scan.bullet_1" = "Toto je odhad HRV pomocí kamery.";
"hrv.onboarding.camera_scan.bullet_2" = "Je užitečný pro trendy, pokud měříte pečlivě.";
"hrv.onboarding.camera_scan.bullet_3" = "Není to EKG ani lékařská diagnóza.";
"hrv.onboarding.best_time.title" = "Kdy měřit";
"hrv.onboarding.best_time.body" = "Pro nejlepší trend měřte každé ráno ve stejnou dobu před kofeinem, jídlem, tréninkem nebo pracovním stresem.";
"hrv.onboarding.best_time.bullet_1" = "Měřte po probuzení.";
"hrv.onboarding.best_time.bullet_2" = "Měřte před kofeinem nebo jídlem.";
"hrv.onboarding.best_time.bullet_3" = "Každý den používejte stejnou polohu těla.";
"hrv.onboarding.best_time.bullet_4" = "Snažte se měřit ve stejném ranním časovém okně.";
"hrv.onboarding.preparation.title" = "Než začnete";
"hrv.onboarding.preparation.body" = "Klid je důležitý. HRV je citlivé, takže nejčistší skeny vznikají, když je tělo klidné a prst zůstává nehybný.";
"hrv.onboarding.preparation.bullet_1" = "Sedněte si nebo si lehněte.";
"hrv.onboarding.preparation.bullet_2" = "Odpočiňte si jednu až dvě minuty.";
"hrv.onboarding.preparation.bullet_3" = "Pokud máte studené prsty, zahřejte si ruce.";
"hrv.onboarding.preparation.bullet_4" = "Dýchejte normálně a nemluvte.";
"hrv.onboarding.finger_placement.title" = "Jemně přiložte prst";
"hrv.onboarding.finger_placement.body" = "Zcela zakryjte zadní kameru bříškem prstu. Použijte jemný, rovnoměrný tlak. Pokud tlačíte příliš silně, mění se průtok krve a sken je méně spolehlivý.";
"hrv.onboarding.finger_placement.bullet_1" = "Zcela zakryjte kameru.";
"hrv.onboarding.finger_placement.bullet_2" = "Netlačte příliš silně.";
"hrv.onboarding.finger_placement.bullet_3" = "Držte prst v klidu.";
"hrv.onboarding.during_scan.title" = "Během skenu";
"hrv.onboarding.during_scan.body" = "Jen normálně dýchejte. Nesnažte se skóre zlepšit. Cílem je zachytit váš skutečný stav.";
"hrv.onboarding.during_scan.bullet_1" = "Zůstaňte v klidu.";
"hrv.onboarding.during_scan.bullet_2" = "Nemluvte.";
"hrv.onboarding.during_scan.bullet_3" = "Dýchejte přirozeně.";
"hrv.onboarding.scan_length.title" = "Vyberte hloubku skenu";
