"hrv.onboarding.what_is_hrv.title" = "Vad är HRV?";
"hrv.onboarding.what_is_hrv.body" = "HRV betyder hjärtfrekvensvariabilitet. Det mäter små förändringar i tiden mellan dina hjärtslag.";
"hrv.onboarding.what_is_hrv.bullet_1" = "Ditt hjärta slår inte som en perfekt metronom.";
"hrv.onboarding.what_is_hrv.bullet_2" = "En flexibel rytm kan spegla bättre anpassningsförmåga i nervsystemet.";
"hrv.onboarding.what_is_hrv.bullet_3" = "HRV kan påverkas av sömn, stress, sjukdom, träning, alkohol, koffein, vätskebalans och känslomässig press.";
"hrv.onboarding.camera_scan.title" = "Så fungerar skanningen med telefonen";
"hrv.onboarding.camera_scan.body" = "Kameran ser små färgförändringar i din fingertopp. Dessa förändringar följer din pulsvåg, och appen uppskattar tiden mellan slagen.";
"hrv.onboarding.camera_scan.bullet_1" = "Detta är en kamerabaserad HRV-uppskattning.";
"hrv.onboarding.camera_scan.bullet_2" = "Den är användbar för trender när den mäts noggrant.";
"hrv.onboarding.camera_scan.bullet_3" = "Det är inte EKG och ingen medicinsk diagnos.";
"hrv.onboarding.best_time.title" = "När du ska mäta";
"hrv.onboarding.best_time.body" = "För bästa trend, mät vid samma tid varje morgon före koffein, mat, träning eller arbetsstress.";
"hrv.onboarding.best_time.bullet_1" = "Mät efter uppvaknandet.";
"hrv.onboarding.best_time.bullet_2" = "Mät före koffein eller mat.";
"hrv.onboarding.best_time.bullet_3" = "Använd samma kroppsställning varje dag.";
"hrv.onboarding.best_time.bullet_4" = "Försök mäta inom samma morgonfönster.";
"hrv.onboarding.preparation.title" = "Innan du börjar";
"hrv.onboarding.preparation.body" = "Stillhet är viktig. HRV är känsligt, så de renaste skanningarna sker när kroppen är lugn och fingret stilla.";
"hrv.onboarding.preparation.bullet_1" = "Sitt eller ligg ner.";
"hrv.onboarding.preparation.bullet_2" = "Vila en till två minuter.";
"hrv.onboarding.preparation.bullet_3" = "Värm händerna om fingrarna är kalla.";
"hrv.onboarding.preparation.bullet_4" = "Andas normalt och prata inte.";
"hrv.onboarding.finger_placement.title" = "Placera fingret försiktigt";
"hrv.onboarding.finger_placement.body" = "Täck den bakre kameran helt med din fingertopp. Använd lätt, jämnt tryck. Trycker du för hårt ändras blodflödet och skanningen blir mindre tillförlitlig.";
"hrv.onboarding.finger_placement.bullet_1" = "Täck kameran helt.";
"hrv.onboarding.finger_placement.bullet_2" = "Tryck inte för hårt.";
"hrv.onboarding.finger_placement.bullet_3" = "Håll fingret stilla.";
"hrv.onboarding.during_scan.title" = "Under skanningen";
"hrv.onboarding.during_scan.body" = "Andas bara normalt. Försök inte förbättra poängen. Målet är att fånga ditt verkliga tillstånd.";
"hrv.onboarding.during_scan.bullet_1" = "Var stilla.";
"hrv.onboarding.during_scan.bullet_2" = "Prata inte.";
"hrv.onboarding.during_scan.bullet_3" = "Fortsätt andas naturligt.";
"hrv.onboarding.scan_length.title" = "Välj skanningsdjup";
"hrv.onboarding.scan_length.body" = "Korta skanningar är användbara för dagliga trender. Längre skanningar låser upp djupare HRV-mått.";
"hrv.onboarding.scan_length.bullet_1" = "Snabbskanning: 60 till 120 sekunder för daglig beredskap.";
"hrv.onboarding.scan_length.bullet_2" = "Standardskanning: 5 minuter för djupare analys.";
"hrv.onboarding.scan_length.bullet_3" = "Djupskanning: 300 rena slag eller mer för avancerade HRV-mått.";
"hrv.onboarding.results.title" = "Hur du läser ditt resultat";
"hrv.onboarding.results.body" = "En skanning är en ögonblicksbild. Din personliga trend är viktigare än ett enskilt värde.";
"hrv.onboarding.results.bullet_1" = "Din personliga baslinje betyder mer än ett generellt intervall.";
"hrv.onboarding.results.bullet_2" = "Lågt HRV kan spegla stress, dålig sömn, sjukdom, uttorkning, alkohol eller hård träning.";
"hrv.onboarding.results.bullet_3" = "Högt HRV kan betyda god återhämtning, men om du känner dig utmattad kan det också spegla återhämtningsbehov.";
"hrv.onboarding.daily_guidance.title" = "Din dagliga vägledning";
"hrv.onboarding.daily_guidance.body" = "Appen använder din HRV-trend för att göra dagliga påminnelser mer personliga.";
"hrv.onboarding.daily_guidance.bullet_1" = "Om du mätte idag kan påminnelser innehålla HRV-baserad vägledning.";
"hrv.onboarding.daily_guidance.bullet_2" = "Om du inte har mätt påminner appen dig vänligt om att göra en skanning.";
"hrv.onboarding.daily_guidance.bullet_3" = "Ju mer regelbundet du mäter, desto bättre blir din vägledning.";
"hrv.onboarding.limitations.title" = "Viktiga begränsningar";
"hrv.onboarding.limitations.body" = "HRV är ingen medicinsk diagnos. Den här appen upptäcker inte hjärtsjukdom, arytmier eller akuta nödsituationer.";
"hrv.onboarding.limitations.bullet_1" = "Kamera-HRV är en uppskattning, inte EKG.";
"hrv.onboarding.limitations.bullet_2" = "Rörelse, kalla fingrar, tryck, medicin och arytmier kan påverka noggrannheten.";
"hrv.onboarding.limitations.bullet_3" = "Vid bröstsmärta, svimningskänsla, svår andnöd eller ovanliga symtom, sök vård.";
"hrv.onboarding.first_scan.title" = "Redo för din första skanning?";
"hrv.onboarding.first_scan.body" = "Gör din första lugna skanning nu så att appen kan börja bygga din personliga HRV-baslinje.";
"hrv.onboarding.first_scan.primary_cta" = "Starta HRV-skanning";
"hrv.onboarding.first_scan.secondary_cta" = "Påminn mig senare";
