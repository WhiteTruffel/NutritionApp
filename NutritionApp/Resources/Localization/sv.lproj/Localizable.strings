"hrv.metrics.rmssd.title" = "RMSSD";
"hrv.metrics.rmssd.short" = "Kortsiktig variabilitet";
"hrv.metrics.rmssd.meaning" = "RMSSD speglar slag-till-slag-förändringar som främst drivs av den parasympatiska (återhämtande) grenen av ditt nervsystem.";
"hrv.metrics.rmssd.low" = "Lägre RMSSD än vanligt kan spegla stress, dålig sömn, sjukdom eller hård träning.";
"hrv.metrics.rmssd.high" = "Högre RMSSD speglar ofta god återhämtning, även om ovanligt höga värden med trötthet kan betyda återhämtningsbehov.";
"hrv.metrics.rmssd.reliability" = "Tillförlitlig även på korta, lugna skanningar.";
"hrv.metrics.sdnn.title" = "SDNN";
"hrv.metrics.sdnn.short" = "Total variabilitet";
"hrv.metrics.sdnn.meaning" = "SDNN fångar den totala spridningen av dina intervallängder och speglar båda grenarna av ditt nervsystem.";
"hrv.metrics.sdnn.low" = "Lägre SDNN kan spegla minskad total anpassningsförmåga.";
"hrv.metrics.sdnn.high" = "Högre SDNN speglar generellt större total variabilitet.";
"hrv.metrics.sdnn.reliability" = "Mer tillförlitlig på längre skanningar.";
"hrv.metrics.pnn50.title" = "pNN50";
"hrv.metrics.pnn50.short" = "Andel stora slagförändringar";
"hrv.metrics.pnn50.meaning" = "pNN50 är andelen intilliggande slag som skiljer sig med mer än 50 ms, en annan parasympatisk markör.";
"hrv.metrics.pnn50.low" = "Ett lågt pNN50 kan följa med stress eller trötthet.";
"hrv.metrics.pnn50.high" = "Ett högre pNN50 följer oftast med avslappnade, väl återhämtade tillstånd.";
"hrv.metrics.pnn50.reliability" = "Användbar på korta skanningar, men brusigare än RMSSD.";
"hrv.metrics.amo50.title" = "AMo50";
"hrv.metrics.amo50.short" = "Slagklustring";
"hrv.metrics.amo50.meaning" = "AMo50 beskriver hur tätt dina intervall klustrar kring det vanligaste värdet; tätare klustring tyder på mer sympatisk aktivering.";
"hrv.metrics.amo50.low" = "Ett lägre AMo50 tyder på en mer avslappnad, variabel rytm.";
"hrv.metrics.amo50.high" = "Ett högre AMo50 tyder på en stelare, mer aktiverad rytm.";
"hrv.metrics.amo50.reliability" = "Bäst på standard- eller längre skanningar.";
"hrv.metrics.lfhf.title" = "LF/HF";
"hrv.metrics.lfhf.short" = "Frekvensbalans (endast kontext)";
